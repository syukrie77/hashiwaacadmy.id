---
import Layout from "../../../../layouts/Layout.astro";
import { supabase } from "../../../../lib/supabase";

const { courseId, id } = Astro.params;
export const prerender = false;

if (!courseId || !id) {
    return Astro.redirect("/404");
}

const user = Astro.locals.user;
if (!user) {
    return Astro.redirect("/login");
}

// Fetch assignment details
const { data: assignment, error: assignError } = await supabase
    .from("assignments")
    .select(
        `
    *,
    classes (title)
  `,
    )
    .eq("id", id)
    .single();

if (assignError || !assignment) {
    console.error("Error fetching assignment:", assignError);
    return Astro.redirect("/404");
}

// Check for existing submission
// In a real app, this logic would check the current user's submission
---

<Layout>
    <div id="user-data" data-user={JSON.stringify(user)} class="hidden"></div>
    <div class="assignment-page">
        <div class="header">
            <a href={`/courses/${courseId}`} class="back-link"
                >← Back to Course</a
            >
            <h1>{assignment.title}</h1>
            <p class="course-name">{assignment.classes.title}</p>
        </div>

        <div class="main-layout">
            <section class="details-card">
                <h3>Instructions</h3>
                <div class="description">
                    {assignment.description || "No instructions provided."}
                </div>

                {
                    assignment.deadline && (
                        <div class="deadline">
                            <strong>Deadline:</strong>{" "}
                            {new Date(assignment.deadline).toLocaleString()}
                        </div>
                    )
                }
            </section>

            <aside class="submission-card">
                <h3>My Submission</h3>
                <form id="submission-form">
                    <div class="form-group">
                        <label for="file_url">Solution Link (URL)</label>
                        <input
                            type="url"
                            id="file_url"
                            name="file_url"
                            required
                            placeholder="https://github.com/..."
                        />
                    </div>
                    <button type="submit" class="btn btn-primary btn-block"
                        >Submit Assignment</button
                    >
                </form>
                <div id="submission-status" class="hidden">
                    <p class="success-msg">
                        Assignment submitted successfully!
                    </p>
                </div>
            </aside>
        </div>
    </div>
</Layout>

<script define:vars={{ assignmentId: id }}>
    const form = document.getElementById("submission-form");
    const statusDiv = document.getElementById("submission-status");

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const userEl = document.getElementById("user-data");
        const userStr = userEl ? userEl.dataset.user : null;
        if (!userStr || userStr === "null") {
            alert("Please log in for submission");
            return;
        }

        const user = JSON.parse(userStr);
        const formData = new FormData(e.target);
        const file_url = formData.get("file_url");

        const { supabase } = await import("../../../../lib/supabase");

        const { data, error } = await supabase.from("submissions").insert([
            {
                assignment_id: assignmentId,
                user_id: user.id,
                file_url: file_url,
            },
        ]);

        if (error) {
            console.error(error);
            alert("Error submitting: " + error.message);
        } else {
            form.classList.add("hidden");
            statusDiv.classList.remove("hidden");
        }
    });
</script>

<style>
    .assignment-page {
        max-width: 1000px;
        margin: 0 auto;
    }

    .header {
        margin-bottom: 2rem;
    }

    .back-link {
        text-decoration: none;
        color: #6b7280;
        font-size: 0.875rem;
    }

    .course-name {
        color: var(--primary-color);
        font-weight: 600;
        margin-top: -0.5rem;
    }

    .main-layout {
        display: grid;
        grid-template-columns: 1fr 350px;
        gap: 2rem;
    }

    @media (max-width: 768px) {
        .main-layout {
            grid-template-columns: 1fr;
        }
    }

    .details-card,
    .submission-card {
        background: white;
        padding: 2rem;
        border-radius: 0.5rem;
        border: 1px solid var(--border-color);
    }

    h3 {
        margin-top: 0;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 1rem;
        margin-bottom: 1.5rem;
    }

    .description {
        line-height: 1.6;
        color: #374151;
        white-space: pre-wrap;
    }

    .deadline {
        margin-top: 2rem;
        padding: 1rem;
        background: #fff7ed;
        border-radius: 0.375rem;
        color: #9a3412;
        font-size: 0.9rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    label {
        display: block;
        font-size: 0.875rem;
        font-weight: 500;
        margin-bottom: 0.5rem;
    }

    input {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid #d1d5db;
        border-radius: 0.375rem;
        box-sizing: border-box;
    }

    .btn-block {
        width: 100%;
    }

    .hidden {
        display: none;
    }

    .success-msg {
        color: #059669;
        font-weight: 600;
        text-align: center;
    }
</style>
