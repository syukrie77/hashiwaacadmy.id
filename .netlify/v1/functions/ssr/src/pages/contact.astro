---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kontak Kami" description="Hubungi Hashiwa Japanese Academy — konsultasikan perjalanan bahasa Jepang Anda bersama kami.">
	<!-- Hero -->
	<section class="contact-hero">
		<span class="badge-accent">Hubungi Kami</span>
		<h1>Ada Pertanyaan? <span class="text-primary">Kami Siap Membantu.</span></h1>
		<p>Konsultasikan program belajar bahasa Jepang Anda langsung dengan tim kami.</p>
	</section>

	<!-- Contact Grid -->
	<section class="contact-grid">
		<!-- Contact Cards -->
		<div class="contact-cards">
			<div class="contact-card">
				<div class="card-icon">📞</div>
				<h3>Telepon / WhatsApp</h3>
				<p>Hubungi kami langsung melalui WhatsApp untuk respons cepat.</p>
				<a href="https://wa.me/6208776022000" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
					0877 6022 000
				</a>
			</div>

			<div class="contact-card">
				<div class="card-icon">📍</div>
				<h3>Kantor Indonesia</h3>
				<p>Prima Harapan Regency<br />Ruko PHR Loft EC-11<br />Kota Bekasi, Indonesia</p>
				<a href="https://maps.google.com/?q=Prima+Harapan+Regency+Bekasi" target="_blank" rel="noopener noreferrer" class="link-map">
					Lihat di Google Maps →
				</a>
			</div>

			<div class="contact-card">
				<div class="card-icon">🇯🇵</div>
				<h3>Kantor Jepang</h3>
				<p>8F Keihan Yodoyabashi Building<br />3-2-25 Kitahama, Chuo-ku<br />Osaka-shi, Osaka 541-0041 Japan</p>
			</div>

			<div class="contact-card">
				<div class="card-icon">📸</div>
				<h3>Instagram</h3>
				<p>Ikuti kami untuk info terbaru, konten belajar, dan testimoni alumni.</p>
				<a href="https://instagram.com/hashiwaacademy" target="_blank" rel="noopener noreferrer" class="btn btn-outline">
					@hashiwaacademy
				</a>
			</div>
		</div>

		<!-- WhatsApp CTA -->
		<div class="wa-cta">
			<div class="wa-icon">💬</div>
			<h2>Konsultasi Gratis via WhatsApp</h2>
			<p>
				Tim konsultan kami siap membantu Anda memilih program yang tepat sesuai
				tujuan karier Anda — baik untuk bekerja di Jepang maupun di perusahaan
				Jepang di Indonesia.
			</p>
			<ul class="benefit-list">
				<li>✅ Konsultasi program Tokutei Ginou, Techno Shoku, dan Reguler</li>
				<li>✅ Info biaya kursus dan metode pembayaran</li>
				<li>✅ Jadwal kelas online dan offline</li>
				<li>✅ Proses penempatan kerja ke Jepang</li>
			</ul>
			<a href="https://wa.me/6208776022000?text=Halo%20Hashiwa%2C%20saya%20ingin%20konsultasi%20program%20kursus%20bahasa%20Jepang" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
				Chat WhatsApp Sekarang
			</a>
		</div>
	</section>

	<!-- Map Section -->
	<section class="map-section">
		<h2>Lokasi Kami</h2>
		<div class="map-embed">
			<iframe
				src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.2!2d106.97!3d-6.23!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sPrima+Harapan+Regency+Bekasi!5e0!3m2!1sen!2sid!4v1600000000000!5m2!1sen!2sid"
				width="100%"
				height="400"
				style="border:0;"
				allowfullscreen=""
				loading="lazy"
				referrerpolicy="no-referrer-when-downgrade"
				title="Lokasi Hashiwa Japanese Academy, Bekasi"
			></iframe>
		</div>
		<p class="map-address">
			<strong>Hashiwa Japanese Academy</strong> — Prima Harapan Regency, Ruko PHR Loft EC-11, Kota Bekasi, Indonesia
		</p>
	</section>
</Layout>

<style>
	.contact-hero {
		text-align: center;
		padding: 4rem 0 2rem;
	}

	.contact-hero h1 {
		font-size: 3rem;
		font-weight: 800;
		margin: 1rem 0 1.5rem;
		color: #111827;
		line-height: 1.2;
	}

	.contact-hero p {
		font-size: 1.2rem;
		color: #4b5563;
		max-width: 500px;
		margin: 0 auto;
	}

	.text-primary {
		color: var(--primary-color);
	}

	.badge-accent {
		color: #92400e;
		background: #fef3c7;
		padding: 0.25rem 0.75rem;
		border-radius: 999px;
		font-size: 0.875rem;
		font-weight: 700;
		display: inline-block;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		margin: 3rem 0;
		align-items: start;
	}

	.contact-cards {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.contact-card {
		background: white;
		border: 1px solid var(--border-color);
		border-radius: 1.25rem;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.card-icon {
		font-size: 2rem;
	}

	.contact-card h3 {
		font-size: 1rem;
		font-weight: 700;
		margin: 0;
		color: #111827;
	}

	.contact-card p {
		font-size: 0.9rem;
		color: #6b7280;
		margin: 0;
		line-height: 1.5;
		flex: 1;
	}

	.link-map {
		color: var(--primary-color);
		font-weight: 600;
		font-size: 0.875rem;
		text-decoration: none;
	}

	.link-map:hover {
		text-decoration: underline;
	}

	/* WhatsApp CTA */
	.wa-cta {
		background: #111827;
		border-radius: 2rem;
		padding: 3rem;
		color: white;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.wa-icon {
		font-size: 2.5rem;
	}

	.wa-cta h2 {
		font-size: 1.75rem;
		font-weight: 800;
		margin: 0;
	}

	.wa-cta p {
		color: rgba(255, 255, 255, 0.75);
		line-height: 1.6;
		margin: 0;
	}

	.benefit-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.benefit-list li {
		color: rgba(255, 255, 255, 0.85);
		font-size: 0.9rem;
	}

	.btn-lg {
		padding: 0.875rem 2rem;
		font-size: 1.05rem;
		text-align: center;
	}

	/* Map */
	.map-section {
		margin: 3rem 0 4rem;
	}

	.map-section h2 {
		font-size: 1.75rem;
		font-weight: 800;
		margin-bottom: 1.5rem;
		color: #111827;
	}

	.map-embed {
		border-radius: 1.5rem;
		overflow: hidden;
		border: 1px solid var(--border-color);
	}

	.map-address {
		margin-top: 1rem;
		color: #4b5563;
		font-size: 0.9rem;
	}

	/* Buttons */
	.btn {
		padding: 0.5rem 1rem;
		border-radius: 0.375rem;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.2s;
		display: inline-block;
		text-align: center;
	}

	.btn-outline {
		border: 1px solid var(--border-color);
		color: var(--text-color);
		background: white;
	}

	.btn-outline:hover {
		border-color: var(--primary-color);
		color: var(--primary-color);
	}

	.btn-primary {
		background-color: var(--primary-color);
		color: #000000;
		border: 1px solid var(--primary-color);
	}

	.btn-primary:hover {
		background-color: var(--primary-hover);
	}

	/* Responsive */
	@media (max-width: 768px) {
		.contact-hero h1 {
			font-size: 2rem;
		}

		.contact-grid {
			grid-template-columns: 1fr;
		}

		.contact-cards {
			grid-template-columns: 1fr;
		}

		.wa-cta {
			padding: 2rem 1.5rem;
		}
	}
</style>
