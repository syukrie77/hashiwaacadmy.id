---
import Layout from "../../../../../layouts/Layout.astro";
const { id, examId } = Astro.params;
export const prerender = false;

const user = Astro.locals.user;
if (!user || (user.role !== "instructor" && user.role !== "admin")) {
    return Astro.redirect("/login");
}
---

<Layout>
    <div id="user-data" data-user={JSON.stringify(user)} class="hidden"></div>
    <div class="page-container">
        <div class="page-header">
            <div>
                <a href={`/instructor/courses/${id}/exams`} class="back-link">← Kembali ke Daftar Ujian</a>
                <h1 id="exam-title">Kelola Soal Ujian</h1>
                <p id="exam-meta" class="muted">Loading...</p>
            </div>
            <div class="header-actions">
                <button id="edit-exam-btn" class="btn btn-outline">Edit Info Ujian</button>
                <button id="publish-btn" class="btn btn-primary">Publish Ujian</button>
            </div>
        </div>

        <div id="loading" class="state-msg">Memuat soal...</div>

        <div id="content" class="hidden">
            <div class="toolbar">
                <h2>Daftar Soal (<span id="q-count">0</span>)</h2>
                <button id="add-question-btn" class="btn btn-primary">+ Tambah Soal</button>
            </div>

            <div id="questions-list"></div>

            <div id="no-questions" class="empty-state hidden">
                <p>📝 Belum ada soal. Klik "Tambah Soal" untuk memulai.</p>
                <p class="hint">Soal bisa berupa: Pilihan Ganda, Essay, atau Benar/Salah</p>
            </div>
        </div>
    </div>

    <!-- Add/Edit Question Modal -->
    <div id="question-modal" class="modal hidden">
        <div class="modal-content large">
            <h3 id="modal-title">Tambah Soal</h3>
            <form id="question-form">
                <input type="hidden" id="q-edit-id" value="" />
                <div class="form-group">
                    <label>Tipe Soal *</label>
                    <select id="q-type" required>
                        <option value="multiple_choice">Pilihan Ganda</option>
                        <option value="essay">Essay</option>
                        <option value="true_false">Benar / Salah</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Pertanyaan *</label>
                    <textarea id="q-text" rows="4" required placeholder="Tulis pertanyaan di sini..."></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Poin</label>
                        <input type="number" id="q-points" value="10" min="1" />
                    </div>
                    <div class="form-group">
                        <label>Nomor Urut</label>
                        <input type="number" id="q-order" value="1" min="1" />
                    </div>
                </div>

                <!-- MCQ Options -->
                <div id="mcq-section">
                    <h4>Pilihan Jawaban</h4>
                    <div id="options-list">
                        <div class="option-row">
                            <input type="radio" name="correct_option" value="0" checked />
                            <input type="text" class="option-input" placeholder="Pilihan A" data-idx="0" />
                            <button type="button" class="btn-x remove-option">×</button>
                        </div>
                        <div class="option-row">
                            <input type="radio" name="correct_option" value="1" />
                            <input type="text" class="option-input" placeholder="Pilihan B" data-idx="1" />
                            <button type="button" class="btn-x remove-option">×</button>
                        </div>
                    </div>
                    <button type="button" id="add-option-btn" class="btn btn-sm btn-outline">+ Tambah Pilihan</button>
                </div>

                <!-- True/False Section -->
                <div id="tf-section" class="hidden">
                    <div class="form-group">
                        <label>Jawaban Benar</label>
                        <select id="tf-answer">
                            <option value="true">Benar</option>
                            <option value="false">Salah</option>
                        </select>
                    </div>
                </div>

                <!-- Essay note -->
                <div id="essay-note" class="hidden info-box">
                    ℹ️ Soal essay akan dikoreksi secara manual oleh guru. Siswa menulis jawaban dalam bentuk teks.
                </div>

                <div class="modal-actions">
                    <button type="button" class="btn btn-outline" id="cancel-q">Batal</button>
                    <button type="submit" class="btn btn-primary">Simpan Soal</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Exam Modal -->
    <div id="edit-exam-modal" class="modal hidden">
        <div class="modal-content">
            <h3>Edit Info Ujian</h3>
            <form id="edit-exam-form">
                <div class="form-group">
                    <label>Judul Ujian</label>
                    <input type="text" id="edit-title" required />
                </div>
                <div class="form-group">
                    <label>Deskripsi</label>
                    <textarea id="edit-desc" rows="3"></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Durasi (menit)</label>
                        <input type="number" id="edit-duration" min="10" />
                    </div>
                    <div class="form-group">
                        <label>Passing Score</label>
                        <input type="number" id="edit-passing" min="0" max="100" />
                    </div>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn btn-outline" id="cancel-edit-exam">Batal</button>
                    <button type="submit" class="btn btn-primary">Simpan</button>
                </div>
            </form>
        </div>
    </div>
</Layout>

<script>
    import { supabase } from "../../../../../lib/supabase";

    const pathParts = window.location.pathname.split("/");
    // Path: /instructor/courses/[id]/exams/[examId]
    // Index:  [0]      [1]      [2]   [3]   [4]     [5]
    const courseId = pathParts[3];
    const examId = pathParts[5];

    let questions: any[] = [];
    let editingId: string | null = null;

    const loadingEl = document.getElementById("loading");
    const contentEl = document.getElementById("content");
    const questionsList = document.getElementById("questions-list");
    const noQuestionsEl = document.getElementById("no-questions");
    const qCountEl = document.getElementById("q-count");
    const qModal = document.getElementById("question-modal");
    const editExamModal = document.getElementById("edit-exam-modal");

    async function init() {
        // Fetch exam info
        const { data: exam } = await supabase
            .from("exams")
            .select("*")
            .eq("id", examId)
            .single();

        if (exam) {
            document.getElementById("exam-title")!.textContent = exam.title;
            document.getElementById("exam-meta")!.textContent =
                `${exam.description || "Tidak ada deskripsi"} | Durasi: ${exam.duration || 60} menit | Passing: ${exam.passing_score || 60}%`;

            (document.getElementById("edit-title") as HTMLInputElement).value = exam.title;
            (document.getElementById("edit-desc") as HTMLTextAreaElement).value = exam.description || "";
            (document.getElementById("edit-duration") as HTMLInputElement).value = String(exam.duration || 60);
            (document.getElementById("edit-passing") as HTMLInputElement).value = String(exam.passing_score || 60);

            if (exam.is_published) {
                document.getElementById("publish-btn")!.textContent = "✅ Published";
                (document.getElementById("publish-btn") as HTMLButtonElement).disabled = true;
            }
        }

        await loadQuestions();
    }

    async function loadQuestions() {
        let { data, error } = await supabase
            .from("questions")
            .select("*, question_options(*)")
            .eq("exam_id", examId)
            .order("order_no", { ascending: true });

        // Fallback 1: if order_no column doesn't exist, retry without ordering
        if (error && error.message?.includes("order_no")) {
            console.warn("order_no column missing, retrying without order");
            const fb1 = await supabase
                .from("questions")
                .select("*, question_options(*)")
                .eq("exam_id", examId);
            data = fb1.data;
            error = fb1.error;
        }

        // Fallback 2: if question_options join fails, retry without it
        if (error && error.message?.includes("question_options")) {
            console.warn("question_options join failed, retrying without join");
            const fb2 = await supabase
                .from("questions")
                .select("*")
                .eq("exam_id", examId);
            data = fb2.data;
            error = fb2.error;
        }

        // Fallback 3: if RLS blocks, show helpful message
        if (error) {
            console.error("Questions load error:", error);
            loadingEl!.textContent = "Gagal memuat soal. Error: " + (error.message || "Unknown. Pastikan: 1) Jalankan fix_exam_rls_for_students.sql, 2) Jalankan fix_exam_publish_status.sql, 3) Tabel questions & question_options sudah ada.");
            return;
        }

        questions = data || [];
        loadingEl!.classList.add("hidden");
        contentEl!.classList.remove("hidden");
        qCountEl!.textContent = String(questions.length);

        if (questions.length === 0) {
            noQuestionsEl!.classList.remove("hidden");
            questionsList!.innerHTML = "";
            return;
        }

        noQuestionsEl!.classList.add("hidden");
        renderQuestions();
    }

    function renderQuestions() {
        questionsList!.innerHTML = questions.map((q: any, i: number) => {
            const typeLabel = q.type === "multiple_choice" ? "📋 Pilihan Ganda" :
                q.type === "essay" ? "✍️ Essay" : "✅ Benar/Salah";
            const points = q.points || 10;
            const options = q.question_options || [];

            return `
                <div class="question-card">
                    <div class="q-header">
                        <div class="q-number">${i + 1}</div>
                        <div class="q-info">
                            <span class="q-type-badge">${typeLabel}</span>
                            <span class="q-points">${points} poin</span>
                        </div>
                        <div class="q-actions">
                            <button class="btn btn-sm btn-outline edit-q" data-id="${q.id}">Edit</button>
                            <button class="btn btn-sm btn-danger delete-q" data-id="${q.id}">Hapus</button>
                        </div>
                    </div>
                    <div class="q-text">${q.question}</div>
                    ${q.type === "multiple_choice" && options.length > 0 ? `
                        <div class="q-options">
                            ${options.map((o: any) => `
                                <div class="q-option ${o.is_correct ? "correct" : ""}">
                                    ${o.is_correct ? "✅" : "○"} ${o.option_text}
                                </div>
                            `).join("")}
                        </div>
                    ` : ""}
                    ${q.type === "true_false" ? `<div class="q-options"><div class="q-option correct">Jawaban: ${q.correct_answer === "true" ? "Benar" : "Salah"}</div></div>` : ""}
                    ${q.type === "essay" ? `<div class="essay-hint">✍️ Soal essay - akan dikoreksi manual</div>` : ""}
                </div>
            `;
        }).join("");

        // Attach listeners
        document.querySelectorAll(".edit-q").forEach((btn) => {
            (btn as HTMLButtonElement).onclick = () => editQuestion((btn as HTMLElement).dataset.id!);
        });
        document.querySelectorAll(".delete-q").forEach((btn) => {
            (btn as HTMLButtonElement).onclick = async () => {
                if (confirm("Hapus soal ini?")) {
                    const qId = (btn as HTMLElement).dataset.id;
                    // Delete options first
                    await supabase.from("question_options").delete().eq("question_id", qId);
                    await supabase.from("questions").delete().eq("id", qId);
                    await loadQuestions();
                }
            };
        });
    }

    function editQuestion(qId: string) {
        const q = questions.find((q: any) => q.id === qId);
        if (!q) return;

        editingId = qId;
        (document.getElementById("modal-title") as HTMLElement).textContent = "Edit Soal";
        (document.getElementById("q-edit-id") as HTMLInputElement).value = qId;
        (document.getElementById("q-type") as HTMLSelectElement).value = q.type || "multiple_choice";
        (document.getElementById("q-text") as HTMLTextAreaElement).value = q.question;
        (document.getElementById("q-points") as HTMLInputElement).value = String(q.points || 10);
        (document.getElementById("q-order") as HTMLInputElement).value = String(q.order_no || 1);

        toggleTypeSections();

        if (q.type === "multiple_choice" && q.question_options) {
            const optList = document.getElementById("options-list")!;
            optList.innerHTML = "";
            q.question_options.forEach((o: any, i: number) => {
                addOptionRow(i, o.option_text, o.is_correct);
            });
        }

        if (q.type === "true_false") {
            (document.getElementById("tf-answer") as HTMLSelectElement).value = q.correct_answer || "true";
        }

        qModal!.classList.remove("hidden");
    }

    // Type toggle
    const qTypeSelect = document.getElementById("q-type") as HTMLSelectElement;
    qTypeSelect.onchange = toggleTypeSections;

    function toggleTypeSections() {
        const type = qTypeSelect.value;
        document.getElementById("mcq-section")!.classList.toggle("hidden", type !== "multiple_choice");
        document.getElementById("tf-section")!.classList.toggle("hidden", type !== "true_false");
        document.getElementById("essay-note")!.classList.toggle("hidden", type !== "essay");
    }

    // Option management
    function addOptionRow(idx: number, text: string = "", correct: boolean = false) {
        const optList = document.getElementById("options-list")!;
        const row = document.createElement("div");
        row.className = "option-row";
        row.innerHTML = `
            <input type="radio" name="correct_option" value="${idx}" ${correct ? "checked" : ""} />
            <input type="text" class="option-input" placeholder="Pilihan ${String.fromCharCode(65 + idx)}" value="${text}" data-idx="${idx}" />
            <button type="button" class="btn-x remove-option">×</button>
        `;
        optList.appendChild(row);

        row.querySelector(".remove-option")!.onclick = () => {
            if (optList.children.length > 2) {
                row.remove();
            } else {
                alert("Minimal 2 pilihan harus ada.");
            }
        };
    }

    document.getElementById("add-option-btn")!.onclick = () => {
        const optList = document.getElementById("options-list")!;
        const nextIdx = optList.children.length;
        addOptionRow(nextIdx);
    };

    // Add question button
    document.getElementById("add-question-btn")!.onclick = () => {
        editingId = null;
        (document.getElementById("modal-title") as HTMLElement).textContent = "Tambah Soal";
        (document.getElementById("q-edit-id") as HTMLInputElement).value = "";
        (document.getElementById("question-form") as HTMLFormElement).reset();
        (document.getElementById("q-points") as HTMLInputElement).value = "10";
        (document.getElementById("q-order") as HTMLInputElement).value = String(questions.length + 1);

        // Reset options
        const optList = document.getElementById("options-list")!;
        optList.innerHTML = "";
        addOptionRow(0);
        addOptionRow(1);

        toggleTypeSections();
        qModal!.classList.remove("hidden");
    };

    document.getElementById("cancel-q")!.onclick = () => qModal!.classList.add("hidden");

    // Submit question
    document.getElementById("question-form")!.onsubmit = async (e) => {
        e.preventDefault();

        const type = (document.getElementById("q-type") as HTMLSelectElement).value;
        const questionText = (document.getElementById("q-text") as HTMLTextAreaElement).value;
        const points = parseInt((document.getElementById("q-points") as HTMLInputElement).value);
        const orderNo = parseInt((document.getElementById("q-order") as HTMLInputElement).value);

        let correctAnswer: string | null = null;
        if (type === "true_false") {
            correctAnswer = (document.getElementById("tf-answer") as HTMLSelectElement).value;
        }

        const qData: any = {
            exam_id: examId,
            question: questionText,
            type,
            points,
            order_no: orderNo,
            correct_answer: correctAnswer,
        };

        let questionId: string;

        if (editingId) {
            // Update existing
            await supabase.from("question_options").delete().eq("question_id", editingId);
            await supabase.from("questions").update(qData).eq("id", editingId);
            questionId = editingId;
        } else {
            // Create new
            const { data, error } = await supabase
                .from("questions")
                .insert(qData)
                .select("id")
                .single();

            if (error) {
                alert("Gagal menyimpan soal: " + error.message);
                return;
            }
            questionId = data.id;
        }

        // Save MCQ options
        if (type === "multiple_choice") {
            const correctIdx = parseInt((document.querySelector('input[name="correct_option"]:checked') as HTMLInputElement)?.value || "0");
            const optionInputs = document.querySelectorAll(".option-input") as NodeListOf<HTMLInputElement>;

            const options = Array.from(optionInputs).map((input, i) => ({
                question_id: questionId,
                option_text: input.value,
                is_correct: i === correctIdx,
                order_no: i + 1,
            }));

            const { error: optError } = await supabase.from("question_options").insert(options);
            if (optError) {
                alert("Gagal menyimpan pilihan: " + optError.message);
                return;
            }
        }

        qModal!.classList.add("hidden");
        await loadQuestions();
    };

    // Publish exam
    document.getElementById("publish-btn")!.onclick = async () => {
        if (questions.length === 0) {
            alert("Tambahkan minimal 1 soal sebelum publish.");
            return;
        }
        if (confirm("Publish ujian ini? Siswa akan bisa mengerjakannya.")) {
            await supabase.from("exams").update({ is_published: true }).eq("id", examId);
            location.reload();
        }
    };

    // Edit exam info
    document.getElementById("edit-exam-btn")!.onclick = () => editExamModal!.classList.remove("hidden");
    document.getElementById("cancel-edit-exam")!.onclick = () => editExamModal!.classList.add("hidden");

    document.getElementById("edit-exam-form")!.onsubmit = async (e) => {
        e.preventDefault();
        const title = (document.getElementById("edit-title") as HTMLInputElement).value;
        const description = (document.getElementById("edit-desc") as HTMLTextAreaElement).value;
        const duration = parseInt((document.getElementById("edit-duration") as HTMLInputElement).value);
        const passing_score = parseInt((document.getElementById("edit-passing") as HTMLInputElement).value);

        await supabase
            .from("exams")
            .update({ title, description: description || null, duration, passing_score })
            .eq("id", examId);

        editExamModal!.classList.add("hidden");
        location.reload();
    };

    init();
</script>

<style>
    .page-container { max-width: 1000px; margin: 0 auto; padding: 2rem; }
    .page-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
    .page-header h1 { margin: 0.5rem 0 0 0; font-size: 1.5rem; }
    .back-link { color: #6b7280; text-decoration: none; font-size: 0.875rem; }
    .muted { color: #6b7280; margin: 0; font-size: 0.9rem; }
    .header-actions { display: flex; gap: 0.5rem; }
    .state-msg { text-align: center; padding: 3rem; color: #6b7280; }
    .hidden { display: none !important; }

    .toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .toolbar h2 { margin: 0; font-size: 1.1rem; }

    .question-card {
        background: white; border: 1px solid #e2e8f0; border-radius: 0.75rem;
        padding: 1.25rem; margin-bottom: 1rem; box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    }
    .q-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
    .q-number {
        background: #2563eb; color: white; width: 32px; height: 32px;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 0.875rem; flex-shrink: 0;
    }
    .q-info { display: flex; gap: 0.5rem; flex: 1; }
    .q-type-badge { background: #dbeafe; color: #1e40af; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
    .q-points { background: #fef3c7; color: #92400e; padding: 0.2rem 0.6rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
    .q-actions { display: flex; gap: 0.375rem; }
    .q-text { font-size: 0.95rem; line-height: 1.6; color: #1e293b; padding-left: 48px; }
    .q-options { padding-left: 48px; margin-top: 0.5rem; }
    .q-option { padding: 0.375rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; margin-bottom: 0.25rem; background: #f8fafc; }
    .q-option.correct { background: #dcfce7; color: #166534; font-weight: 500; }
    .essay-hint { padding-left: 48px; margin-top: 0.5rem; color: #6366f1; font-size: 0.8rem; font-style: italic; }

    .btn { padding: 0.5rem 1rem; border-radius: 0.375rem; font-weight: 600; cursor: pointer; border: none; font-size: 0.875rem; }
    .btn-sm { padding: 0.375rem 0.75rem; font-size: 0.8rem; }
    .btn-primary { background: #2563eb; color: white; }
    .btn-primary:hover { background: #1d4ed8; }
    .btn-primary:disabled { background: #93c5fd; cursor: default; }
    .btn-outline { background: white; border: 1px solid #d1d5db; color: #374151; }
    .btn-outline:hover { background: #f9fafb; }
    .btn-danger { background: #fee2e2; color: #dc2626; border: 1px solid #fecaca; }
    .btn-x { background: #fee2e2; color: #dc2626; border: none; width: 28px; height: 28px; border-radius: 50%; cursor: pointer; font-size: 1rem; display: flex; align-items: center; justify-content: center; }

    .empty-state { text-align: center; padding: 4rem 2rem; background: white; border: 2px dashed #e2e8f0; border-radius: 1rem; color: #6b7280; }
    .hint { font-size: 0.85rem; color: #94a3b8; margin-top: 0.5rem; }

    .modal { position: fixed; inset: 0; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 100; }
    .modal-content { background: white; padding: 2rem; border-radius: 0.75rem; width: 500px; max-width: 90vw; max-height: 90vh; overflow-y: auto; }
    .modal-content.large { width: 700px; }
    .modal-content h3 { margin: 0 0 1.5rem 0; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { display: block; font-size: 0.875rem; font-weight: 600; margin-bottom: 0.375rem; color: #374151; }
    .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 0.625rem; border: 1px solid #d1d5db; border-radius: 0.375rem; font-family: inherit; box-sizing: border-box; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 1.5rem; }

    .option-row { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
    .option-row input[type="radio"] { flex-shrink: 0; }
    .option-row input[type="text"] { flex: 1; padding: 0.5rem; border: 1px solid #d1d5db; border-radius: 0.375rem; }

    .info-box { background: #dbeafe; border: 1px solid #93c5fd; padding: 1rem; border-radius: 0.5rem; color: #1e40af; font-size: 0.875rem; margin-top: 1rem; }

    h4 { margin: 1rem 0 0.5rem 0; font-size: 0.9rem; color: #374151; }
</style>