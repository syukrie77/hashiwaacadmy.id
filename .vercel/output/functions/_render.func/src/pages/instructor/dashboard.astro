---
import Layout from "../../layouts/Layout.astro";
export const prerender = false;

const user = Astro.locals.user;
if (!user || user.role !== "instructor") {
    return Astro.redirect("/login");
}
---

<Layout>
    <div id="user-data" data-user={JSON.stringify(user)} class="hidden"></div>
    <div class="instructor-container">
        <div class="header">
            <div class="welcome">
                <h1>Instructor Dashboard</h1>
                <p>Kelola metrics, course, dan materi pembelajaran Anda</p>
            </div>
        </div>

        <div id="loading" class="state-message">
            <div class="spinner"></div>
            <p>Memuat data course...</p>
        </div>

        <div id="dashboard-content" class="hidden">
            <div class="analytics-grid">
                <div class="stat-card">
                    <div class="stat-label">Total Siswa</div>
                    <div id="stat-students" class="stat-value">0</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Course Aktif</div>
                    <div id="stat-active-courses" class="stat-value">0</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Total Modul</div>
                    <div id="stat-modules" class="stat-value">0</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Total Materi</div>
                    <div id="stat-materials" class="stat-value">0</div>
                </div>
            </div>

            <div class="section-header">
                <h3>Course Saya</h3>
            </div>
            <div id="courses-grid" class="courses-grid">
                <!-- Courses will be rendered here -->
            </div>
            <div id="no-courses" class="empty-state hidden">
                <p>Anda belum memiliki course.</p>
                <p class="muted">
                    Hubungi admin untuk menambahkan Anda sebagai instructor
                    course.
                </p>
            </div>
        </div>
    </div>
</Layout>

<script>
    import { supabase } from "../../lib/supabase";

    const userEl = document.getElementById("user-data");
    const userStr = userEl ? userEl.dataset.user : null;
    const loadingEl = document.getElementById("loading");
    const contentEl = document.getElementById("dashboard-content");
    const coursesGrid = document.getElementById("courses-grid");
    const noCoursesEl = document.getElementById("no-courses");
    const statStudents = document.getElementById("stat-students");
    const statActiveCourses = document.getElementById("stat-active-courses");
    const statModules = document.getElementById("stat-modules");
    const statMaterials = document.getElementById("stat-materials");

    if (!userStr) {
        window.location.href = "/login";
    } else {
        const user = JSON.parse(userStr);

        // Check if user is instructor
        if (user.role !== "instructor") {
            alert("Akses ditolak. Halaman ini khusus untuk Instructor.");
            window.location.href = "/dashboard";
        } else {
            loadDashboardData(user);
        }
    }

    async function loadDashboardData(user: any) {
        try {
            console.log("Dashboard - Current User:", user);
            // 1. Fetch courses owned by user
            const { data: courses, error: coursesError } = await supabase
                .from("classes")
                .select("*")
                .eq("owner_id", user.id)
                .order("title");

            if (coursesError) {
                console.error(
                    "Dashboard - Error fetching courses:",
                    coursesError,
                );
                throw coursesError;
            } else {
                console.log("Dashboard - Courses fetched:", courses);
            }

            if (!courses || courses.length === 0) {
                console.warn("Dashboard - No courses found for this user.");
                loadingEl!.style.display = "none";
                contentEl!.classList.remove("hidden");
                noCoursesEl!.classList.remove("hidden");
                return;
            }

            // 2. Fetch metrics
            const courseIds = courses.map((c) => c.id);

            // Count total enrollments for these courses
            const { count: totalStudents } = await supabase
                .from("enrollments")
                .select("*", { count: "exact", head: true })
                .in("class_id", courseIds);

            // Count total modules
            const { count: totalModules } = await (supabase as any)
                .from("modules")
                .select("*", { count: "exact", head: true })
                .in("class_id", courseIds);

            // Count total materials (need to join modules)
            const { count: totalMaterials } = await (supabase as any)
                .from("materials")
                .select("id, modules!inner(class_id)", {
                    count: "exact",
                    head: true,
                })
                .in("modules.class_id", courseIds);

            // Update UI stats
            if (statStudents)
                statStudents.textContent = totalStudents?.toString() || "0";
            if (statActiveCourses)
                statActiveCourses.textContent = courses
                    .filter((c) => c.is_active)
                    .length.toString();
            if (statModules)
                statModules.textContent = totalModules?.toString() || "0";
            if (statMaterials)
                statMaterials.textContent = totalMaterials?.toString() || "0";

            loadingEl!.style.display = "none";
            contentEl!.classList.remove("hidden");

            // Render Courses
            renderCourses(courses);
        } catch (err) {
            console.error(err);
            alert("Error memuat data dashboard");
            loadingEl!.textContent = "Gagal memuat data.";
        }
    }

    function renderCourses(courses: any[]) {
        courses.forEach((course) => {
            const card = document.createElement("div");
            card.className = "course-card";
            card.innerHTML = `
                <div class="course-info">
                    <h4>${course.title}</h4>
                    <p class="muted">${course.description || "Tidak ada deskripsi"}</p>
                    <div class="course-meta">
                        <span class="badge ${course.is_active ? "active" : "inactive"}">
                            ${course.is_active ? "Aktif" : "Draft"}
                        </span>
                        ${course.price > 0 ? `<span class="price">Rp ${course.price.toLocaleString("id-ID")}</span>` : '<span class="price free">Gratis</span>'}
                    </div>
                </div>
                <div class="course-actions">
                    <a href="/instructor/courses/${course.id}/builder" class="btn btn-primary">
                        Kelola Materi
                    </a>
                    <a href="/instructor/courses/${course.id}/students" class="btn btn-outline">
                        Lihat Siswa
                    </a>
                </div>
            `;
            coursesGrid?.appendChild(card);
        });
    }
</script>

<style>
    .instructor-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .header {
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header h1 {
        margin: 0;
        font-size: 2rem;
    }

    .header p {
        color: #6b7280;
        margin-top: 0.5rem;
    }

    .analytics-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }

    .stat-card {
        background: white;
        padding: 1.5rem;
        border-radius: 0.75rem;
        border: 1px solid var(--border-color);
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
    }

    .stat-label {
        font-size: 0.875rem;
        color: #6b7280;
        margin-bottom: 0.5rem;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary-color);
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .section-header h3 {
        margin: 0;
    }

    .courses-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 1.5rem;
    }

    .course-card {
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 0.75rem;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .course-info h4 {
        margin: 0 0 0.5rem 0;
        font-size: 1.25rem;
    }

    .course-info .muted {
        font-size: 0.9rem;
        color: #6b7280;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .course-meta {
        display: flex;
        gap: 0.75rem;
        margin-top: 1rem;
        align-items: center;
    }

    .badge {
        padding: 0.25rem 0.75rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .badge.active {
        background: #dcfce7;
        color: #166534;
    }

    .badge.inactive {
        background: #fef3c7;
        color: #92400e;
    }

    .price {
        font-weight: 600;
        color: var(--primary-color);
    }

    .price.free {
        color: #059669;
    }

    .course-actions {
        display: flex;
        gap: 0.75rem;
        margin-top: auto;
    }

    .course-actions .btn {
        flex: 1;
        text-align: center;
        text-decoration: none;
        padding: 0.5rem;
        border-radius: 0.375rem;
        font-weight: 500;
        font-size: 0.9rem;
    }

    .btn-primary {
        background: var(--primary-color);
        color: white;
    }

    .btn-outline {
        background: white;
        border: 1px solid #ccc;
        color: var(--text-color);
    }

    .btn-outline:hover {
        background: #f9fafb;
    }

    .empty-state {
        text-align: center;
        padding: 3rem;
        background: #f9fafb;
        border-radius: 0.75rem;
    }

    .empty-state p {
        margin: 0.5rem 0;
    }

    .state-message {
        text-align: center;
        padding: 3rem;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 3px solid #e5e7eb;
        border-top-color: var(--primary-color);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 0 auto 1rem;
    }

    @keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .hidden {
        display: none !important;
    }

    @media (max-width: 768px) {
        .courses-grid {
            grid-template-columns: 1fr;
        }

        .course-actions {
            flex-direction: column;
        }
    }
</style>
