---
import Layout from "../../../../layouts/Layout.astro";
const { id } = Astro.params;
export const prerender = false;

const user = Astro.locals.user;
if (!user || (user.role !== "instructor" && user.role !== "admin")) {
    return Astro.redirect("/login");
}
---

<Layout>
    <div id="user-data" data-user={JSON.stringify(user)} class="hidden"></div>
    <div class="page-container">
        <div class="page-header">
            <div>
                <a href={`/instructor/courses/${id}`} class="back-link">← Kembali ke Course</a>
                <h1>Kelola Ujian</h1>
                <p id="course-title" class="muted">Loading...</p>
            </div>
            <button id="create-exam-btn" class="btn btn-primary">+ Buat Ujian Baru</button>
        </div>

        <div id="loading" class="state-msg">Memuat data ujian...</div>

        <div id="exams-content" class="hidden">
            <div id="exams-list" class="exams-grid"></div>
            <div id="no-exams" class="empty-state hidden">
                <p>Belum ada ujian. Klik "Buat Ujian Baru" untuk memulai.</p>
            </div>
        </div>
    </div>

    <!-- ==================== CREATE EXAM WIZARD MODAL ==================== -->
    <div id="create-modal" class="modal hidden">
        <div class="wizard-content">
            <!-- Wizard Header -->
            <div class="wizard-header">
                <h3 id="wizard-title">Buat Ujian Baru</h3>
                <button id="close-wizard" class="close-btn">&times;</button>
            </div>

            <!-- Step Indicators -->
            <div class="steps-indicator">
                <div class="step-item active" data-step="1">
                    <div class="step-num">1</div>
                    <div class="step-label">Info Ujian</div>
                </div>
                <div class="step-line"></div>
                <div class="step-item" data-step="2">
                    <div class="step-num">2</div>
                    <div class="step-label">Soal-soal</div>
                </div>
                <div class="step-line"></div>
                <div class="step-item" data-step="3">
                    <div class="step-num">3</div>
                    <div class="step-label">Review</div>
                </div>
            </div>

            <!-- STEP 1: Exam Info -->
            <div id="step-1" class="wizard-step">
                <div class="step-section">
                    <h4>📋 Informasi Ujian</h4>
                    <div class="form-group">
                        <label>Judul Ujian *</label>
                        <input type="text" id="exam-title" required placeholder="contoh: Ujian Tengah Semester" />
                    </div>
                    <div class="form-group">
                        <label>Deskripsi / Instruksi</label>
                        <textarea id="exam-desc" rows="3" placeholder="Instruksi untuk siswa, misalnya: 'Jawab semua soal dengan benar. Soal essay akan dikoreksi manual.'"></textarea>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Durasi (menit) *</label>
                            <input type="number" id="exam-duration" value="60" min="5" required />
                            <small class="form-hint">Waktu yang diberikan ke siswa</small>
                        </div>
                        <div class="form-group">
                            <label>Passing Score (%) *</label>
                            <input type="number" id="exam-passing" value="60" min="0" max="100" required />
                            <small class="form-hint">Nilai minimum untuk lulus</small>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Acak Soal?</label>
                        <label class="toggle-label">
                            <input type="checkbox" id="exam-shuffle" />
                            <span class="toggle-switch"></span>
                            <span>Acak urutan soal untuk setiap siswa</span>
                        </label>
                    </div>
                </div>
                <div class="wizard-footer">
                    <div></div>
                    <button id="to-step-2" class="btn btn-primary">Selanjutnya: Tambah Soal →</button>
                </div>
            </div>

            <!-- STEP 2: Questions -->
            <div id="step-2" class="wizard-step hidden">
                <div class="step-section">
                    <div class="questions-toolbar">
                        <h4>📝 Kelola Soal (<span id="temp-q-count">0</span>)</h4>
                        <button id="add-question-btn" class="btn btn-primary btn-sm">+ Tambah Soal</button>
                    </div>
                    <div class="form-hint" style="margin-bottom:1rem">Tambahkan soal pilihan ganda, essay, atau benar/salah. Soal bisa diedit atau dihapus kapan saja sebelum publish.</div>

                    <div id="temp-questions-list"></div>
                    <div id="no-temp-questions" class="empty-state-sm">
                        <p>📝 Belum ada soal. Klik "Tambah Soal" untuk memulai.</p>
                    </div>
                </div>

                <!-- Add Question Inline Form -->
                <div id="add-question-panel" class="hidden">
                    <div class="question-form-card">
                        <div class="qf-header">
                            <h4 id="qf-title">Tambah Soal Baru</h4>
                            <button id="cancel-add-q" class="btn-x">&times;</button>
                        </div>
                        <form id="question-form">
                            <input type="hidden" id="q-edit-idx" value="-1" />
                            <div class="form-group">
                                <label>Tipe Soal *</label>
                                <select id="q-type" required>
                                    <option value="multiple_choice">📋 Pilihan Ganda</option>
                                    <option value="essay">✍️ Essay</option>
                                    <option value="true_false">✅ Benar / Salah</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Pertanyaan *</label>
                                <textarea id="q-text" rows="4" required placeholder="Tulis pertanyaan di sini..."></textarea>
                            </div>
                            <div class="form-row-3">
                                <div class="form-group">
                                    <label>Poin</label>
                                    <input type="number" id="q-points" value="10" min="1" max="100" />
                                </div>
                                <div class="form-group">
                                    <label>Nomor Urut</label>
                                    <input type="number" id="q-order" value="1" min="1" />
                                </div>
                            </div>

                            <!-- MCQ Options -->
                            <div id="mcq-section">
                                <label class="section-label">Pilihan Jawaban <small>(pilih radio untuk jawaban benar)</small></label>
                                <div id="options-list">
                                    <div class="option-row">
                                        <input type="radio" name="correct_option" value="0" checked />
                                        <span class="option-letter">A</span>
                                        <input type="text" class="option-input" placeholder="Pilihan A" />
                                        <button type="button" class="btn-x remove-option" disabled title="Minimal 2 pilihan">×</button>
                                    </div>
                                    <div class="option-row">
                                        <input type="radio" name="correct_option" value="1" />
                                        <span class="option-letter">B</span>
                                        <input type="text" class="option-input" placeholder="Pilihan B" />
                                        <button type="button" class="btn-x remove-option" disabled title="Minimal 2 pilihan">×</button>
                                    </div>
                                </div>
                                <button type="button" id="add-option-btn" class="btn btn-sm btn-outline">+ Tambah Pilihan</button>
                            </div>

                            <!-- True/False Section -->
                            <div id="tf-section" class="hidden">
                                <div class="form-group">
                                    <label>Jawaban Benar</label>
                                    <div class="tf-options">
                                        <label class="tf-option">
                                            <input type="radio" name="tf_answer" value="true" checked />
                                            <span class="tf-badge tf-true">✅ Benar</span>
                                        </label>
                                        <label class="tf-option">
                                            <input type="radio" name="tf_answer" value="false" />
                                            <span class="tf-badge tf-false">❌ Salah</span>
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Essay note -->
                            <div id="essay-note" class="hidden info-box">
                                ℹ️ Soal essay akan dikoreksi secara manual oleh guru setelah siswa mengumpulkan jawaban.
                            </div>

                            <div class="qf-actions">
                                <button type="button" class="btn btn-outline" id="cancel-q">Batal</button>
                                <button type="submit" class="btn btn-primary" id="save-q-btn">Simpan Soal</button>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="wizard-footer">
                    <button id="back-to-step-1" class="btn btn-outline">← Kembali</button>
                    <button id="to-step-3" class="btn btn-primary">Selanjutnya: Review →</button>
                </div>
            </div>

            <!-- STEP 3: Review & Save -->
            <div id="step-3" class="wizard-step hidden">
                <div class="step-section">
                    <h4>🔍 Review Ujian</h4>
                    <div id="review-content"></div>
                </div>
                <div class="wizard-footer">
                    <button id="back-to-step-2" class="btn btn-outline">← Kembali</button>
                    <button id="save-exam-btn" class="btn btn-primary btn-lg">💾 Simpan & Buat Ujian</button>
                </div>
            </div>
        </div>
    </div>
</Layout>

<script>
    import { supabase } from "../../../../lib/supabase";

    const pathParts = window.location.pathname.split("/");
    const courseId = pathParts[pathParts.length - 2];

    const loadingEl = document.getElementById("loading");
    const contentEl = document.getElementById("exams-content");
    const examsList = document.getElementById("exams-list");
    const noExamsEl = document.getElementById("no-exams");
    const createModal = document.getElementById("create-modal");
    const courseTitleEl = document.getElementById("course-title");

    // ==================== TEMP QUESTION STATE ====================
    let tempQuestions: any[] = [];
    let editingIdx = -1;

    // ==================== LOAD EXAMS LIST ====================
    async function init() {
        const { data: course } = await supabase
            .from("classes")
            .select("title")
            .eq("id", courseId)
            .single();

        if (course) courseTitleEl!.textContent = course.title;

        const { data: exams, error } = await supabase
            .from("exams")
            .select("*")
            .eq("class_id", courseId)
            .order("id", { ascending: false });

        if (error) {
            console.error("Error fetching exams:", error);
            loadingEl!.textContent = "Gagal memuat data ujian.";
            return;
        }

        loadingEl!.classList.add("hidden");
        contentEl!.classList.remove("hidden");

        if (!exams || exams.length === 0) {
            noExamsEl!.classList.remove("hidden");
            return;
        }

        const examIds = exams.map((e: any) => e.id);
        const { data: submissions } = await supabase
            .from("exam_submissions")
            .select("exam_id, status")
            .in("exam_id", examIds);

        const subMap: Record<string, { total: number; graded: number; pending: number }> = {};
        submissions?.forEach((s: any) => {
            if (!subMap[s.exam_id]) subMap[s.exam_id] = { total: 0, graded: 0, pending: 0 };
            subMap[s.exam_id].total++;
            if (s.status === "graded") subMap[s.exam_id].graded++;
            if (s.status === "submitted") subMap[s.exam_id].pending++;
        });

        const { data: questions } = await supabase
            .from("questions")
            .select("exam_id")
            .in("exam_id", examIds);

        const qMap: Record<string, number> = {};
        questions?.forEach((q: any) => {
            qMap[q.exam_id] = (qMap[q.exam_id] || 0) + 1;
        });

        exams.forEach((exam: any) => {
            const subs = subMap[exam.id] || { total: 0, graded: 0, pending: 0 };
            const qCount = qMap[exam.id] || 0;
            const isPublished = exam.is_published;

            const card = document.createElement("div");
            card.className = "exam-card";
            card.innerHTML = `
                <div class="exam-card-header">
                    <div>
                        <h3 class="exam-title">${exam.title}</h3>
                        <p class="exam-meta">${exam.description || "Tidak ada deskripsi"}</p>
                    </div>
                    <span class="badge ${isPublished ? "badge-published" : "badge-draft"}">
                        ${isPublished ? "✅ Published" : "📝 Draft"}
                    </span>
                </div>
                <div class="exam-stats">
                    <div class="stat"><span class="stat-num">${qCount}</span><span class="stat-label">Soal</span></div>
                    <div class="stat"><span class="stat-num">${exam.duration || 60}</span><span class="stat-label">Menit</span></div>
                    <div class="stat"><span class="stat-num">${exam.passing_score || 60}%</span><span class="stat-label">Passing</span></div>
                    <div class="stat"><span class="stat-num">${subs.total}</span><span class="stat-label">Submissions</span></div>
                    <div class="stat"><span class="stat-num warning">${subs.pending}</span><span class="stat-label">Belum Dikoreksi</span></div>
                    <div class="stat"><span class="stat-num success">${subs.graded}</span><span class="stat-label">Dikoreksi</span></div>
                </div>
                <div class="exam-actions">
                    <a href="/instructor/courses/${courseId}/exams/${exam.id}" class="btn btn-sm btn-outline">Kelola Soal</a>
                    <a href="/instructor/courses/${courseId}/grading?examId=${exam.id}" class="btn btn-sm ${subs.total > 0 ? 'btn-primary' : 'btn-outline'}">
                        ✅ Koreksi Jawaban ${subs.total > 0 ? `(${subs.pending} belum)` : '(0 jawaban)'}
                    </a>
                    <button class="btn btn-sm btn-outline toggle-publish" data-id="${exam.id}" data-published="${isPublished}">
                        ${isPublished ? "Unpublish" : "Publish"}
                    </button>
                    <button class="btn btn-sm btn-danger delete-exam" data-id="${exam.id}">Hapus</button>
                </div>
            `;
            examsList!.appendChild(card);
        });

        document.querySelectorAll(".toggle-publish").forEach((btn) => {
            (btn as HTMLButtonElement).onclick = async () => {
                const eid = (btn as HTMLElement).dataset.id;
                const isPub = (btn as HTMLElement).dataset.published === "true";
                await supabase.from("exams").update({ is_published: !isPub }).eq("id", eid);
                location.reload();
            };
        });

        document.querySelectorAll(".delete-exam").forEach((btn) => {
            (btn as HTMLButtonElement).onclick = async () => {
                if (confirm("Yakin ingin menghapus ujian ini? Semua soal dan jawaban akan ikut terhapus.")) {
                    const eid = (btn as HTMLElement).dataset.id;
                    await supabase.from("exams").delete().eq("id", eid);
                    location.reload();
                }
            };
        });
    }

    // ==================== WIZARD NAVIGATION ====================
    function goToStep(step: number) {
        document.querySelectorAll(".wizard-step").forEach((el) => el.classList.add("hidden"));
        document.getElementById(`step-${step}`)!.classList.remove("hidden");

        document.querySelectorAll(".step-item").forEach((el) => {
            const s = parseInt((el as HTMLElement).dataset.step || "1");
            el.classList.toggle("active", s === step);
            el.classList.toggle("completed", s < step);
        });
    }

    document.getElementById("create-exam-btn")!.onclick = () => {
        resetWizard();
        createModal!.classList.remove("hidden");
        goToStep(1);
    };

    document.getElementById("close-wizard")!.onclick = () => {
        if (tempQuestions.length > 0 && !confirm("Soal yang sudah ditambahkan akan hilang. Yakin keluar?")) return;
        createModal!.classList.add("hidden");
    };

    // Step 1 -> Step 2
    document.getElementById("to-step-2")!.onclick = () => {
        const title = (document.getElementById("exam-title") as HTMLInputElement).value.trim();
        const duration = (document.getElementById("exam-duration") as HTMLInputElement).value;
        const passing = (document.getElementById("exam-passing") as HTMLInputElement).value;
        if (!title) { alert("Judul ujian wajib diisi."); return; }
        if (!duration || parseInt(duration) < 5) { alert("Durasi minimal 5 menit."); return; }
        (document.getElementById("q-order") as HTMLInputElement).value = String(tempQuestions.length + 1);
        goToStep(2);
    };

    // Step 2 -> Step 1
    document.getElementById("back-to-step-1")!.onclick = () => goToStep(1);

    // Step 2 -> Step 3
    document.getElementById("to-step-3")!.onclick = () => {
        if (tempQuestions.length === 0) {
            alert("Tambahkan minimal 1 soal sebelum melanjutkan.");
            return;
        }
        renderReview();
        goToStep(3);
    };

    // Step 3 -> Step 2
    document.getElementById("back-to-step-2")!.onclick = () => goToStep(2);

    // ==================== QUESTION MANAGEMENT ====================
    document.getElementById("add-question-btn")!.onclick = () => {
        editingIdx = -1;
        (document.getElementById("q-edit-idx") as HTMLInputElement).value = "-1";
        (document.getElementById("qf-title") as HTMLElement).textContent = "Tambah Soal Baru";
        (document.getElementById("save-q-btn") as HTMLElement).textContent = "Simpan Soal";
        (document.getElementById("question-form") as HTMLFormElement).reset();
        (document.getElementById("q-points") as HTMLInputElement).value = "10";
        (document.getElementById("q-order") as HTMLInputElement).value = String(tempQuestions.length + 1);

        // Reset options
        const optList = document.getElementById("options-list")!;
        optList.innerHTML = "";
        addOptionRow("A", true);
        addOptionRow("B", false);

        toggleTypeSections();
        document.getElementById("add-question-panel")!.classList.remove("hidden");
    };

    document.getElementById("cancel-add-q")!.onclick = closeQuestionForm;
    document.getElementById("cancel-q")!.onclick = closeQuestionForm;

    function closeQuestionForm() {
        document.getElementById("add-question-panel")!.classList.add("hidden");
        editingIdx = -1;
    }

    // Type toggle
    const qTypeSelect = document.getElementById("q-type") as HTMLSelectElement;
    qTypeSelect.onchange = toggleTypeSections;

    function toggleTypeSections() {
        const type = qTypeSelect.value;
        document.getElementById("mcq-section")!.classList.toggle("hidden", type !== "multiple_choice");
        document.getElementById("tf-section")!.classList.toggle("hidden", type !== "true_false");
        document.getElementById("essay-note")!.classList.toggle("hidden", type !== "essay");
    }

    // Option management
    function addOptionRow(letter: string, isCorrect: boolean = false) {
        const optList = document.getElementById("options-list")!;
        const idx = optList.children.length;
        const row = document.createElement("div");
        row.className = "option-row";
        row.innerHTML = `
            <input type="radio" name="correct_option" value="${idx}" ${isCorrect ? "checked" : ""} />
            <span class="option-letter">${letter}</span>
            <input type="text" class="option-input" placeholder="Pilihan ${letter}" />
            <button type="button" class="btn-x remove-option" ${optList.children.length < 2 ? 'disabled title="Minimal 2 pilihan"' : ''} title="Hapus pilihan">×</button>
        `;
        optList.appendChild(row);

        row.querySelector(".remove-option")!.addEventListener("click", () => {
            if (optList.children.length > 2) {
                row.remove();
                refreshOptionLetters();
                refreshOptionRadios();
            } else {
                alert("Minimal 2 pilihan harus ada.");
            }
        });
    }

    function refreshOptionLetters() {
        const rows = document.querySelectorAll("#options-list .option-row");
        rows.forEach((row, i) => {
            (row.querySelector(".option-letter") as HTMLElement).textContent = String.fromCharCode(65 + i);
            (row.querySelector(".option-input") as HTMLInputElement).placeholder = `Pilihan ${String.fromCharCode(65 + i)}`;
            const removeBtn = row.querySelector(".remove-option") as HTMLButtonElement;
            removeBtn.disabled = rows.length <= 2;
        });
    }

    function refreshOptionRadios() {
        const rows = document.querySelectorAll("#options-list .option-row");
        rows.forEach((row, i) => {
            (row.querySelector('input[type="radio"]') as HTMLInputElement).value = String(i);
        });
    }

    document.getElementById("add-option-btn")!.onclick = () => {
        const optList = document.getElementById("options-list")!;
        const nextLetter = String.fromCharCode(65 + optList.children.length);
        addOptionRow(nextLetter);
    };

    // Save question to temp array
    document.getElementById("question-form")!.onsubmit = (e) => {
        e.preventDefault();

        const type = (document.getElementById("q-type") as HTMLSelectElement).value;
        const questionText = (document.getElementById("q-text") as HTMLTextAreaElement).value.trim();
        const points = parseInt((document.getElementById("q-points") as HTMLInputElement).value) || 10;
        const orderNo = parseInt((document.getElementById("q-order") as HTMLInputElement).value) || (tempQuestions.length + 1);

        if (!questionText) { alert("Pertanyaan wajib diisi."); return; }

        let correctAnswer: string | null = null;
        let options: any[] = [];

        if (type === "multiple_choice") {
            const correctIdx = parseInt((document.querySelector('input[name="correct_option"]:checked') as HTMLInputElement)?.value || "0");
            const optionInputs = document.querySelectorAll("#options-list .option-input") as NodeListOf<HTMLInputElement>;
            let hasEmpty = false;
            optionInputs.forEach((input) => {
                if (!input.value.trim()) hasEmpty = true;
                options.push({
                    option_text: input.value.trim(),
                    is_correct: false,
                });
            });
            if (hasEmpty) { alert("Semua pilihan jawaban harus diisi."); return; }
            if (options.length < 2) { alert("Minimal 2 pilihan jawaban."); return; }
            options[correctIdx].is_correct = true;
        } else if (type === "true_false") {
            correctAnswer = (document.querySelector('input[name="tf_answer"]:checked') as HTMLInputElement)?.value || "true";
        }

        const qData = {
            type,
            question: questionText,
            points,
            order_no: orderNo,
            correct_answer: correctAnswer,
            options: type === "multiple_choice" ? options : [],
        };

        if (editingIdx >= 0) {
            tempQuestions[editingIdx] = qData;
        } else {
            tempQuestions.push(qData);
        }

        // Sort by order_no
        tempQuestions.sort((a, b) => a.order_no - b.order_no);

        renderTempQuestions();
        closeQuestionForm();
    };

    function renderTempQuestions() {
        const list = document.getElementById("temp-questions-list")!;
        const noQ = document.getElementById("no-temp-questions")!;
        document.getElementById("temp-q-count")!.textContent = String(tempQuestions.length);

        if (tempQuestions.length === 0) {
            list.innerHTML = "";
            noQ.classList.remove("hidden");
            return;
        }

        noQ.classList.add("hidden");
        list.innerHTML = tempQuestions.map((q, i) => {
            const typeLabel = q.type === "multiple_choice" ? "📋 PG" : q.type === "essay" ? "✍️ Essay" : "✅ B/S";
            let detail = "";
            if (q.type === "multiple_choice") {
                detail = q.options.map((o: any) =>
                    `<span class="opt-tag ${o.is_correct ? "opt-correct" : ""}">${o.is_correct ? "✅" : "○"} ${o.option_text}</span>`
                ).join("");
            } else if (q.type === "true_false") {
                detail = `<span class="opt-tag opt-correct">Jawaban: ${q.correct_answer === "true" ? "Benar" : "Salah"}</span>`;
            } else {
                detail = `<span class="opt-tag opt-essay">📝 Dikoreksi manual</span>`;
            }

            return `
                <div class="temp-q-card">
                    <div class="tq-header">
                        <span class="tq-num">${i + 1}</span>
                        <span class="tq-type">${typeLabel}</span>
                        <span class="tq-pts">${q.points} poin</span>
                        <div class="tq-actions">
                            <button class="btn btn-xs btn-outline edit-temp-q" data-idx="${i}">Edit</button>
                            <button class="btn btn-xs btn-danger delete-temp-q" data-idx="${i}">Hapus</button>
                        </div>
                    </div>
                    <div class="tq-text">${q.question}</div>
                    <div class="tq-detail">${detail}</div>
                </div>
            `;
        }).join("");

        // Event listeners
        list.querySelectorAll(".edit-temp-q").forEach((btn) => {
            btn.addEventListener("click", () => editTempQuestion(parseInt((btn as HTMLElement).dataset.idx!)));
        });
        list.querySelectorAll(".delete-temp-q").forEach((btn) => {
            btn.addEventListener("click", () => {
                if (confirm("Hapus soal ini?")) {
                    tempQuestions.splice(parseInt((btn as HTMLElement).dataset.idx!), 1);
                    tempQuestions.forEach((q, i) => q.order_no = i + 1);
                    renderTempQuestions();
                }
            });
        });
    }

    function editTempQuestion(idx: number) {
        const q = tempQuestions[idx];
        if (!q) return;

        editingIdx = idx;
        (document.getElementById("q-edit-idx") as HTMLInputElement).value = String(idx);
        (document.getElementById("qf-title") as HTMLElement).textContent = "Edit Soal";
        (document.getElementById("save-q-btn") as HTMLElement).textContent = "Update Soal";
        (document.getElementById("q-type") as HTMLSelectElement).value = q.type;
        (document.getElementById("q-text") as HTMLTextAreaElement).value = q.question;
        (document.getElementById("q-points") as HTMLInputElement).value = String(q.points);
        (document.getElementById("q-order") as HTMLInputElement).value = String(q.order_no);

        toggleTypeSections();

        if (q.type === "multiple_choice") {
            const optList = document.getElementById("options-list")!;
            optList.innerHTML = "";
            q.options.forEach((o: any, i: number) => {
                addOptionRow(String.fromCharCode(65 + i), o.is_correct);
                (optList.children[i].querySelector(".option-input") as HTMLInputElement).value = o.option_text;
            });
        }

        if (q.type === "true_false") {
            const radio = document.querySelector(`input[name="tf_answer"][value="${q.correct_answer}"]`) as HTMLInputElement;
            if (radio) radio.checked = true;
        }

        document.getElementById("add-question-panel")!.classList.remove("hidden");
    }

    // ==================== REVIEW & SAVE ====================
    function renderReview() {
        const title = (document.getElementById("exam-title") as HTMLInputElement).value;
        const desc = (document.getElementById("exam-desc") as HTMLTextAreaElement).value;
        const duration = (document.getElementById("exam-duration") as HTMLInputElement).value;
        const passing = (document.getElementById("exam-passing") as HTMLInputElement).value;
        const shuffle = (document.getElementById("exam-shuffle") as HTMLInputElement).checked;

        const totalPoints = tempQuestions.reduce((sum, q) => sum + q.points, 0);
        const mcqCount = tempQuestions.filter(q => q.type === "multiple_choice").length;
        const essayCount = tempQuestions.filter(q => q.type === "essay").length;
        const tfCount = tempQuestions.filter(q => q.type === "true_false").length;

        let questionsHtml = tempQuestions.map((q, i) => {
            const typeLabel = q.type === "multiple_choice" ? "📋 Pilihan Ganda" : q.type === "essay" ? "✍️ Essay" : "✅ Benar/Salah";
            let optionsHtml = "";
            if (q.type === "multiple_choice") {
                optionsHtml = `<div class="rv-options">${q.options.map((o: any) =>
                    `<div class="rv-opt ${o.is_correct ? "rv-correct" : ""}">${o.is_correct ? "✅" : "○"} ${o.option_text}</div>`
                ).join("")}</div>`;
            } else if (q.type === "true_false") {
                optionsHtml = `<div class="rv-options"><div class="rv-opt rv-correct">Jawaban: ${q.correct_answer === "true" ? "Benar" : "Salah"}</div></div>`;
            } else {
                optionsHtml = `<div class="rv-note">📝 Akan dikoreksi manual oleh guru</div>`;
            }
            return `
                <div class="rv-question">
                    <div class="rv-q-header">
                        <span class="rv-q-num">${i + 1}</span>
                        <span class="rv-q-type">${typeLabel}</span>
                        <span class="rv-q-pts">${q.points} poin</span>
                    </div>
                    <div class="rv-q-text">${q.question}</div>
                    ${optionsHtml}
                </div>
            `;
        }).join("");

        document.getElementById("review-content")!.innerHTML = `
            <div class="rv-info-card">
                <div class="rv-info-row"><strong>Judul:</strong> ${title}</div>
                ${desc ? `<div class="rv-info-row"><strong>Deskripsi:</strong> ${desc}</div>` : ""}
                <div class="rv-info-row"><strong>Durasi:</strong> ${duration} menit</div>
                <div class="rv-info-row"><strong>Passing Score:</strong> ${passing}%</div>
                <div class="rv-info-row"><strong>Acak Soal:</strong> ${shuffle ? "Ya" : "Tidak"}</div>
                <div class="rv-info-row"><strong>Total Soal:</strong> ${tempQuestions.length} (PG: ${mcqCount}, Essay: ${essayCount}, B/S: ${tfCount})</div>
                <div class="rv-info-row"><strong>Total Poin:</strong> ${totalPoints}</div>
            </div>
            <h4 style="margin:1.5rem 0 1rem">Daftar Soal</h4>
            ${questionsHtml}
        `;
    }

    // Save exam
    document.getElementById("save-exam-btn")!.onclick = async () => {
        const btn = document.getElementById("save-exam-btn") as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = "Menyimpan...";

        try {
            const title = (document.getElementById("exam-title") as HTMLInputElement).value;
            const description = (document.getElementById("exam-desc") as HTMLTextAreaElement).value;
            const duration = parseInt((document.getElementById("exam-duration") as HTMLInputElement).value);
            const passing_score = parseInt((document.getElementById("exam-passing") as HTMLInputElement).value);

            // 1. Create exam
            const { data: exam, error: examError } = await supabase
                .from("exams")
                .insert({
                    class_id: courseId,
                    title,
                    description: description || null,
                    duration,
                    passing_score,
                    is_published: false,
                })
                .select("id")
                .single();

            if (examError) {
                // Try basic insert
                const { data: exam2, error: examError2 } = await supabase
                    .from("exams")
                    .insert({ class_id: courseId, title, duration })
                    .select("id")
                    .single();
                if (examError2) throw new Error(examError2.message);
                await saveQuestions(exam2.id);
            } else {
                await saveQuestions(exam.id);
            }

            alert("✅ Ujian berhasil dibuat dengan " + tempQuestions.length + " soal!");
            createModal!.classList.add("hidden");
            location.reload();
        } catch (err: any) {
            alert("Gagal membuat ujian: " + err.message + "\n\nPastikan sudah menjalankan SQL migration di supabase/manual_grading_exam.sql");
            btn.disabled = false;
            btn.textContent = "💾 Simpan & Buat Ujian";
        }
    };

    async function saveQuestions(examId: string) {
        for (let i = 0; i < tempQuestions.length; i++) {
            const q = tempQuestions[i];

            const { data: question, error: qError } = await supabase
                .from("questions")
                .insert({
                    exam_id: examId,
                    question: q.question,
                    type: q.type,
                    points: q.points,
                    order_no: q.order_no,
                    correct_answer: q.correct_answer,
                })
                .select("id")
                .single();

            if (qError) {
                console.error("Error saving question:", qError);
                continue;
            }

            // Save MCQ options
            if (q.type === "multiple_choice" && q.options.length > 0) {
                const options = q.options.map((o: any, idx: number) => ({
                    question_id: question.id,
                    option_text: o.option_text,
                    is_correct: o.is_correct,
                    order_no: idx + 1,
                }));
                await supabase.from("question_options").insert(options);
            }
        }
    }

    function resetWizard() {
        tempQuestions = [];
        editingIdx = -1;
        (document.getElementById("exam-title") as HTMLInputElement).value = "";
        (document.getElementById("exam-desc") as HTMLTextAreaElement).value = "";
        (document.getElementById("exam-duration") as HTMLInputElement).value = "60";
        (document.getElementById("exam-passing") as HTMLInputElement).value = "60";
        (document.getElementById("exam-shuffle") as HTMLInputElement).checked = false;
        renderTempQuestions();
        document.getElementById("add-question-panel")!.classList.add("hidden");
    }

    init();
</script>

