---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <div class="dashboard-container">
        <div class="header">
            <div class="welcome">
                <h1>Dashboard</h1>
                <p>Welcome back, <span id="user-name">Student</span>!</p>
            </div>
            <div class="header-actions">
                <a href="/profile" class="btn btn-outline">Profile Settings</a>
                <button id="logout-btn" class="btn btn-outline danger"
                    >Sign Out</button
                >
            </div>
        </div>

        <div id="loading" class="state-message">
            <div class="spinner"></div>
            <p>Syncing your learning data...</p>
        </div>

        <div id="dashboard-content" class="hidden">
            <div class="stats-grid">
                <div class="stat-card">
                    <span class="stat-label">Enrolled Courses</span>
                    <span id="stat-courses" class="stat-value">0</span>
                </div>
                <div class="stat-card">
                    <span class="stat-label">Exams Taken</span>
                    <span id="stat-exams" class="stat-value">0</span>
                </div>
            </div>

            <div class="dashboard-grid">
                <section class="main-content">
                    <div class="section-header">
                        <h3>My Courses</h3>
                        <a href="/" class="link">Find more courses →</a>
                    </div>
                    <div id="enrollments-grid" class="course-grid">
                        <!-- Courses will be injected here -->
                    </div>
                    <div id="no-enrollments" class="hidden empty-state">
                        <p>You haven't enrolled in any courses yet.</p>
                        <a href="/" class="btn btn-primary">Browse Courses</a>
                    </div>
                </section>

                <aside class="sidebar">
                    <section>
                        <h3>Recent Results</h3>
                        <ul id="results-list" class="activity-list">
                            <!-- Results injected here -->
                        </ul>
                        <div id="no-results" class="empty-small">
                            No exam records yet
                        </div>
                    </section>
                </aside>
            </div>
        </div>
    </div>
</Layout>

<script>
    import { supabase } from "../lib/supabase";

    const userStr = localStorage.getItem("user");
    const loadingEl = document.getElementById("loading");
    const contentEl = document.getElementById("dashboard-content");
    const userNameEl = document.getElementById("user-name");
    const enrollmentsGrid = document.getElementById("enrollments-grid");
    const noEnrollmentsEl = document.getElementById("no-enrollments");
    const resultsList = document.getElementById("results-list");
    const noResultsEl = document.getElementById("no-results");
    const statCourses = document.getElementById("stat-courses");
    const statExams = document.getElementById("stat-exams");
    const logoutBtn = document.getElementById("logout-btn");

    if (!userStr) {
        window.location.href = "/login";
    } else {
        const user = JSON.parse(userStr);
        userNameEl!.textContent = user.name;

        // Safety: If admin, show a prominent link or redirect (optional)
        if (user.role === "admin") {
            const adminAlert = document.createElement("div");
            adminAlert.style.padding = "1rem";
            adminAlert.style.background = "#fee2e2";
            adminAlert.style.color = "#991b1b";
            adminAlert.style.marginBottom = "1rem";
            adminAlert.style.borderRadius = "0.5rem";
            adminAlert.innerHTML =
                '<strong>Admin detected:</strong> <a href="/admin/dashboard" style="text-decoration: underline; color: inherit;">Manage Platform</a>';
            contentEl?.prepend(adminAlert);
        }

        // Instructor banner
        if (user.role === "instructor") {
            const instructorAlert = document.createElement("div");
            instructorAlert.style.padding = "1rem";
            instructorAlert.style.background = "#d1fae5";
            instructorAlert.style.color = "#065f46";
            instructorAlert.style.marginBottom = "1rem";
            instructorAlert.style.borderRadius = "0.5rem";
            instructorAlert.innerHTML =
                '<strong>Instructor:</strong> <a href="/instructor/dashboard" style="text-decoration: underline; color: inherit;">Kelola Course Anda</a>';
            contentEl?.prepend(instructorAlert);
        }

        loadDashboard(user);
    }

    logoutBtn?.addEventListener("click", () => {
        localStorage.removeItem("user");
        window.location.href = "/";
    });

    async function loadDashboard(user: any) {
        try {
            // 1. Fetch Enrollments
            const { data: enrollments, error: enrollError } = await supabase
                .from("enrollments")
                .select(
                    `
          status,
          classes (id, title, description, price)
        `,
                )
                .eq("user_id", user.id);

            // 2. Fetch Exam Results
            const { data: results, error: resError } = await supabase
                .from("results")
                .select(
                    `
          score,
          exams (title)
        `,
                )
                .eq("user_id", user.id)
                .order("id", { ascending: false })
                .limit(5);

            loadingEl!.style.display = "none";
            contentEl!.classList.remove("hidden");

            if (statCourses)
                statCourses.textContent = enrollments?.length.toString() || "0";
            if (statExams)
                statExams.textContent = results?.length.toString() || "0";

            // Render Enrollments
            if (!enrollments || enrollments.length === 0) {
                noEnrollmentsEl!.classList.remove("hidden");
            } else {
                enrollments.forEach((enroll: any) => {
                    const course = enroll.classes;
                    if (!course) return;
                    const card = document.createElement("div");
                    card.className = "course-card-compact";
                    card.innerHTML = `
            <div class="content">
              <h4>${course.title}</h4>
              <div class="badge status-${enroll.status}">${enroll.status}</div>
            </div>
            <a href="/courses/${course.id}" class="btn btn-sm btn-primary">Go to Class</a>
          `;
                    enrollmentsGrid?.appendChild(card);
                });
            }

            // Render Results
            if (results && results.length > 0) {
                noResultsEl!.classList.add("hidden");
                results.forEach((res: any) => {
                    const li = document.createElement("li");
                    li.innerHTML = `
            <span class="exam-name">${res.exams.title}</span>
            <span class="score ${res.score >= 70 ? "pass" : "fail"}">${res.score}%</span>
          `;
                    resultsList?.appendChild(li);
                });
            }
        } catch (err) {
            console.error(err);
        }
    }
</script>

<style>
    .dashboard-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border-color);
        gap: 1rem;
        flex-wrap: wrap;
    }

    @media (max-width: 640px) {
        .header {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    .welcome h1 {
        margin: 0;
        font-size: 2rem;
    }

    .welcome p {
        margin: 0.25rem 0 0 0;
        color: #6b7280;
    }

    .header-actions {
        display: flex;
        gap: 1rem;
        width: 100%;
        max-width: 400px;
    }

    @media (max-width: 640px) {
        .header-actions {
            max-width: none;
        }
        .header-actions .btn {
            flex: 1;
        }
    }

    .danger:hover {
        color: #ef4444;
        border-color: #ef4444;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
    }

    .stat-card {
        background: white;
        padding: 1.5rem;
        border-radius: 0.75rem;
        border: 1px solid var(--border-color);
    }

    .stat-label {
        display: block;
        font-size: 0.875rem;
        color: #6b7280;
        margin-bottom: 0.5rem;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary-color);
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2.5rem;
    }

    @media (max-width: 900px) {
        .dashboard-grid {
            grid-template-columns: 1fr;
        }
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .section-header h3 {
        margin: 0;
    }

    .link {
        font-size: 0.875rem;
        color: var(--primary-color);
        text-decoration: none;
        font-weight: 500;
    }

    .course-card-compact {
        background: white;
        padding: 1.25rem;
        border: 1px solid var(--border-color);
        border-radius: 0.5rem;
        margin-bottom: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }

    @media (max-width: 640px) {
        .course-card-compact {
            flex-direction: column;
            align-items: flex-start;
        }
        .course-card-compact .btn {
            width: 100%;
        }
    }

    .course-card-compact h4 {
        margin: 0 0 0.25rem 0;
    }

    .badge {
        font-size: 0.7rem;
        text-transform: uppercase;
        font-weight: 700;
        padding: 0.1rem 0.5rem;
        border-radius: 4px;
        background: #f3f4f6;
    }

    .status-active {
        background: #dcfce7;
        color: #166534;
    }

    .activity-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .activity-list li {
        display: flex;
        justify-content: space-between;
        padding: 0.75rem 0;
        border-bottom: 1px solid #f3f4f6;
        font-size: 0.9rem;
    }

    .score {
        font-weight: 700;
    }
    .pass {
        color: #166534;
    }
    .fail {
        color: #991b1b;
    }

    .empty-state {
        text-align: center;
        padding: 4rem;
        background: white;
        border: 2px dashed var(--border-color);
        border-radius: 0.5rem;
    }

    .empty-small {
        font-size: 0.875rem;
        color: #9ca3af;
        padding: 1rem 0;
    }

    .hidden {
        display: none;
    }
</style>
