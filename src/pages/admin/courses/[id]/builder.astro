    .sidebar-footer { padding: 1rem 1.5rem; border-top: 1px solid #334155; }
    .sidebar-footer a { color: #64748b; text-decoration: none; font-size: 0.8rem; }
    .admin-main { flex: 1; padding: 2rem 2.5rem; background: #f8fafc; overflow-y: auto; }
    .admin-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem; }
    .admin-header h1 { margin: 0 0 0.25rem; font-size: 1.5rem; }
    .muted { color: #6b7280; margin: 0; font-size: 0.9rem; }
    .state-message { text-align: center; padding: 3rem; color: #6b7280; }

    /* ── Tabs ── */
    .builder-tabs { display: flex; gap: 0.5rem; margin-bottom: 0; border-bottom: 2px solid #e2e8f0; padding-bottom: 0; }
    .tab-btn { background: none; border: none; padding: 0.75rem 1.25rem; font-weight: 600; font-size: 0.9rem; color: #64748b; cursor: pointer; border-bottom: 3px solid transparent; margin-bottom: -2px; transition: all 0.15s; }
    .tab-btn.active { color: #f59e0b; border-bottom-color: #f59e0b; }
    .tab-content { display: none; padding-top: 1.5rem; }
    .tab-content.active { display: block; }
    .tab-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
    .tab-toolbar h2 { margin: 0; font-size: 1.1rem; }

    /* ── Split Panel ── */
    .split-panel { display: grid; grid-template-columns: 280px 1fr; gap: 1.5rem; min-height: 480px; }
    .modules-panel, .materials-panel {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    .panel-header {
        display: flex; justify-content: space-between; align-items: center;
