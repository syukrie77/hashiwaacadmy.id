    .module-item-count { font-size: 0.75rem; color: #94a3b8; }
    .module-item-actions { display: flex; align-items: center; gap: 0.25rem; opacity: 0; transition: opacity 0.15s; }
    .module-item:hover .module-item-actions { opacity: 1; }
    .btn-icon { background: none; border: none; cursor: pointer; padding: 0.2rem 0.3rem; font-size: 0.85rem; border-radius: 4px; }
    .btn-icon:hover { background: #f1f5f9; }
    .badge-price { font-size: 0.7rem; background: #dcfce7; color: #166534; padding: 0.1rem 0.4rem; border-radius: 4px; }

    /* ── Material Rows ── */
    .material-row { display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; border-bottom: 1px solid #f1f5f9; }
    .mat-reorder { display: flex; flex-direction: column; gap: 1px; }
    .reorder-btn { background: none; border: 1px solid #e2e8f0; border-radius: 3px; cursor: pointer; padding: 0 0.2rem; font-size: 0.6rem; line-height: 1.4; color: #9ca3af; }
    .reorder-btn:hover:not(:disabled) { background: #f1f5f9; color: #374151; }
    .reorder-btn:disabled { opacity: 0.3; cursor: default; }
    .mat-type-badge { font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 4px; font-weight: 600; white-space: nowrap; flex-shrink: 0; }
    .mat-type-video { background: #dbeafe; color: #1e40af; }
    .mat-type-pdf { background: #fee2e2; color: #991b1b; }
    .mat-type-text { background: #d1fae5; color: #065f46; }
    .mat-title { flex: 1; font-size: 0.875rem; font-weight: 500; color: #1e293b; }
    .mat-duration { font-size: 0.75rem; color: #94a3b8; white-space: nowrap; }
    .mat-actions { display: flex; gap: 0.5rem; flex-shrink: 0; }

    /* ── Items List (Assignments / Exams) ── */
    .items-list { background: white; border: 1px solid #e2e8f0; border-radius: 0.75rem; overflow: hidden; }
    .item-row { padding: 1rem 1.25rem; border-bottom: 1px solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
    .item-row:last-child { border-bottom: none; }
    .item-info { display: flex; flex-direction: column; gap: 0.2rem; }
    .item-title { font-weight: 600; font-size: 0.9rem; }
    .item-actions { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .status-badge { font-size: 0.75rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 999px; }
    .badge-published { background: #dcfce7; color: #166534; }
    .badge-draft { background: #fef3c7; color: #92400e; }

    /* ── Buttons ── */
    .btn { padding: 0.5rem 1rem; border-radius: 0.375rem; font-weight: 600; cursor: pointer; border: none; text-decoration: none; display: inline-block; font-size: 0.875rem; transition: all 0.15s; }
    .btn-primary { background: #f59e0b; color: #000; }
    .btn-primary:hover { background: #d97706; }
    .btn-outline { background: white; border: 1px solid #d1d5db; color: #374151; }
    .btn-outline:hover { background: #f9fafb; }
    .btn-sm { padding: 0.3rem 0.6rem; font-size: 0.8rem; border-radius: 0.25rem; cursor: pointer; border: 1px solid #d1d5db; background: white; color: #374151; font-weight: 500; }
    .btn-sm:hover { background: #f9fafb; }
    .btn-danger { padding: 0.3rem 0.6rem; font-size: 0.8rem; border-radius: 0.25rem; background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; cursor: pointer; font-weight: 500; }
    .btn-danger:hover { background: #fecaca; }
    .btn-text-sm { background: none; border: none; color: #6b7280; font-size: 0.8rem; cursor: pointer; text-decoration: underline; padding: 0; }

