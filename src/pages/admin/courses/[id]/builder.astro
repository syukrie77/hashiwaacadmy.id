        border-bottom: 1px solid #e2e8f0;
        flex-shrink: 0;
    }
    .panel-title { font-weight: 700; font-size: 0.875rem; color: #374151; text-transform: uppercase; letter-spacing: 0.05em; }
    .empty-center { display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; padding: 2rem; text-align: center; color: #9ca3af; }
    .empty-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
