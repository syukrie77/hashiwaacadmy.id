        background: white;
        padding: 1.5rem 2rem;
        border-radius: 0.75rem;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        max-width: 360px;
        width: 90%;
        text-align: center;
    }
    .confirm-box p { margin: 0 0 1.25rem; font-size: 0.95rem; color: #1e293b; }
    .confirm-actions { display: flex; gap: 0.75rem; justify-content: center; }
    .btn-danger { background: #ef4444; color: white; border: none; cursor: pointer; padding: 0.5rem 1rem; border-radius: 0.375rem; font-weight: 600; }

    /* ── Layout ── */
    .admin-container { display: flex; min-height: 100vh; margin: -2rem; }
