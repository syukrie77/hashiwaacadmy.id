---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";

const { data: classes, error } = await supabase
	.from("classes")
	.select("*")
	.eq("is_active", true)
	.order("title");

if (error) {
	console.error("Error fetching classes:", error);
}
---

<Layout>
	<section class="hero">
		<h1>Welcome to Hashiwa E-Learning</h1>
		<p>Discover courses and learn at your own pace.</p>
	</section>

	<section class="courses-section">
		<h2>Available Courses</h2>
		{
			!classes || classes.length === 0 ? (
				<p>No courses available at the moment.</p>
			) : (
				<div class="course-grid">
					{classes.map((course) => (
						<div class="course-card">
							<div class="course-content">
								<h3>{course.title}</h3>
								<p class="description">{course.description}</p>
								<div class="footer">
									<span class="price">
										{course.price
											? `Rp ${course.price.toLocaleString("id-ID")}`
											: "Gratis"}
									</span>
									<a
										href={`/courses/${course.id}`}
										class="btn btn-sm btn-primary"
									>
										View Course
									</a>
								</div>
							</div>
						</div>
					))}
				</div>
			)
		}
	</section>
</Layout>

<script>
	import { supabase } from "../lib/supabase";

	async function init() {
		const userStr = localStorage.getItem("user");
		if (!userStr) return;

		const user = JSON.parse(userStr);
		const { data: enrollments } = await supabase
			.from("enrollments")
			.select("class_id")
			.eq("user_id", user.id);

		if (!enrollments) return;

		const enrolledIds = new Set(enrollments.map((e) => e.class_id));
		const courseCards = document.querySelectorAll(".course-card");

		courseCards.forEach((card) => {
			const viewBtn = card.querySelector("a.btn") as HTMLAnchorElement;
			const courseId = viewBtn?.href.split("/").pop();

			if (courseId && enrolledIds.has(courseId)) {
				viewBtn.textContent = "Continue Learning";
				viewBtn.classList.add("btn-success");
				viewBtn.classList.remove("btn-primary");
			}
		});
	}

	init();
	document.addEventListener("astro:after-swap", init);
</script>

<style>
	.btn-success {
		background-color: #10b981;
		color: white;
		border-color: #10b981;
	}
	.btn-success:hover {
		background-color: #059669;
	}
	/* Existing styles... */
	.hero {
		text-align: center;
		padding: 4rem 0;
		background: linear-gradient(135deg, #4f46e5 0%, #818cf8 100%);
		border-radius: 1rem;
		color: white;
		margin-bottom: 3rem;
	}

	.hero h1 {
		font-size: 3rem;
		margin-bottom: 1rem;
	}

	.hero p {
		font-size: 1.25rem;
		opacity: 0.9;
	}

	.course-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 2rem;
	}

	.course-card {
		background: var(--card-bg);
		border: 1px solid var(--border-color);
		border-radius: 0.5rem;
		overflow: hidden;
		transition: box-shadow 0.2s;
	}

	.course-card:hover {
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
	}

	.course-content {
		padding: 1.5rem;
	}

	.course-content h3 {
		margin-top: 0;
		font-size: 1.25rem;
	}

	.description {
		color: #6b7280;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		min-height: 4.5em;
	}

	.footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-top: 1.5rem;
	}

	.price {
		font-weight: 700;
		font-size: 1.1rem;
		color: var(--primary-color);
	}

	.btn-sm {
		padding: 0.25rem 0.75rem;
		font-size: 0.875rem;
	}
</style>
