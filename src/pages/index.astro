---
import Layout from "../layouts/Layout.astro";
import { supabase, isSupabaseConfigured } from "../lib/supabase";

let classes: any[] | null = null;

if (isSupabaseConfigured) {
	try {
		const { data: classesData, error } = await supabase
			.from("classes")
			.select("*")
			.eq("is_active", true)
			.order("title");

		if (error) {
			console.error("Error fetching classes:", error);
		} else {
			classes = classesData as any[] | null;
		}
	} catch (err) {
		console.error("Failed to fetch classes:", err);
	}
}
---

<Layout>
	<!-- Hero Section -->
	<section class="hero-section">
		<div class="hero-content">
			<span class="badge-accent">Japanese Learning Center</span>
			<h1>
				Dari kelas ke karier,<br /><span class="text-primary"
					>Lokal ke Global.</span
				>
			</h1>
			<p>
				Hashiwa Japanese Academy adalah pusat studi bahasa Jepang untuk
				kamu yang siap melangkah lebih jauh. Daftar sekarang dan kuasai
				Jepang bersama kami.
			</p>
			<div class="hero-actions">
				<a href="/register" class="btn btn-primary btn-lg"
					>Daftar Sekarang</a
				>
				<a href="#courses" class="btn btn-outline btn-lg"
					>Lihat Program</a
				>
			</div>
		</div>
		<div class="hero-image">
			<img src="/images/hero-hashiwa.png" alt="Hashiwa Japanese Academy" class="hero-img" />
			<div class="floating-card">
				<span class="dot"></span>
				<span>Top Quality Courses</span>
			</div>
		</div>
	</section>

	<!-- Program Section -->
	<section id="courses" class="courses-section">
		<div class="section-header">
			<div>
				<span class="badge-accent">Top Quality Courses</span>
				<h2>Program Unggulan</h2>
			</div>
			<a href="/courses" class="link-more">Lihat Semua →</a>
		</div>

		{
			(!classes || classes.length === 0) && (
				<div class="empty-state">
					<p>No courses available at the moment.</p>
				</div>
			)
		}

		{
			classes && classes.length > 0 && (
				<div class="course-grid">
					{classes.map((course) => (
						<div class="course-card">
							<div class="course-badge">Course</div>
							<div class="course-content">
								<h3>{course.title}</h3>
								<p class="description">{course.description}</p>
								<div class="footer">
									<span class="price">
										{course.price
											? `Rp ${course.price.toLocaleString("id-ID")}`
											: "Gratis"}
									</span>
									<a
										href={`/courses/${course.id}`}
										class="btn btn-sm btn-primary"
									>
										Lihat Program
									</a>
								</div>
							</div>
						</div>
					))}
				</div>
			)
		}
	</section>

	<!-- Call to Action Section -->
	<section class="cta-section">
		<div class="cta-card">
			<h2>Siap Melangkah Ke Jepang?</h2>
			<p>
				Bergabunglah dengan ratusan alumni kami yang telah sukses
				berkarier di Negeri Sakura.
			</p>
			<a href="/contact" class="btn btn-dark btn-lg">Hubungi Konsultan</a>
		</div>
	</section>
</Layout>

<style>
	/* Hero Styles */
	.hero-section {
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: center;
		gap: 4rem;
		padding: 4rem 0;
		margin-bottom: 4rem;
	}

	.hero-content h1 {
		font-size: 3.5rem;
		font-weight: 800;
		line-height: 1.1;
		margin: 1rem 0 1.5rem;
		color: #111827;
	}

	.text-primary {
		color: var(--primary-color);
	}

	.hero-content p {
		font-size: 1.25rem;
		color: #4b5563;
		margin-bottom: 2.5rem;
		max-width: 500px;
		line-height: 1.6;
	}

	.badge-accent {
		color: #92400e;
		background: #fef3c7;
		padding: 0.25rem 0.75rem;
		border-radius: 999px;
		font-size: 0.875rem;
		font-weight: 700;
		display: inline-block;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
	}

	.btn-lg {
		padding: 0.75rem 2rem;
		font-size: 1.1rem;
	}

	.hero-image {
		position: relative;
	}

	.hero-img {
		width: 100%;
		height: auto;
		border-radius: 2rem;
		display: block;
	}

	.floating-card {
		position: absolute;
		bottom: 2rem;
		left: 2rem;
		background: white;
		padding: 1rem 1.5rem;
		border-radius: 1rem;
		box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-weight: 700;
	}

	.floating-card .dot {
		width: 10px;
		height: 10px;
		background: #10b981;
		border-radius: 50%;
	}

	/* Section Header */
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		margin-bottom: 3rem;
	}

	.section-header h2 {
		font-size: 2.25rem;
		font-weight: 800;
		margin-top: 0.5rem;
	}

	.link-more {
		color: var(--primary-color);
		text-decoration: none;
		font-weight: 700;
	}

	/* Course Grid */
	.course-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 2rem;
	}

	.course-card {
		background: white;
		border: 1px solid var(--border-color);
		border-radius: 1.5rem;
		overflow: hidden;
		transition: all 0.3s ease;
		display: flex;
		flex-direction: column;
	}

	.course-card:hover {
		transform: translateY(-5px);
		box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
		border-color: var(--primary-color);
	}

	.course-badge {
		padding: 1rem 1.5rem 0;
		font-size: 0.75rem;
		font-weight: 800;
		text-transform: uppercase;
		color: #6b7280;
		letter-spacing: 0.05em;
	}

	.course-content {
		padding: 0.5rem 1.5rem 1.5rem;
		flex: 1;
		display: flex;
		flex-direction: column;
	}

	.course-content h3 {
		margin: 0.5rem 0;
		font-size: 1.25rem;
		font-weight: 700;
	}

	.description {
		color: #6b7280;
		font-size: 0.95rem;
		line-height: 1.5;
		margin-bottom: 1.5rem;
		flex: 1;
	}

	.footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 1rem;
		border-top: 1px solid #f3f4f6;
	}

	.price {
		font-weight: 800;
		color: #111827;
	}

	/* CTA Section */
	.cta-section {
		margin: 4rem 0;
	}

	.cta-card {
		background: #111827;
		padding: 4rem;
		border-radius: 2rem;
		color: white;
		text-align: center;
	}

	.cta-card h2 {
		font-size: 2.5rem;
		font-weight: 800;
		margin-bottom: 1rem;
	}

	.cta-card p {
		font-size: 1.25rem;
		opacity: 0.8;
		margin-bottom: 2.5rem;
	}

	.btn-dark {
		background: white;
		color: #111827;
		border: none;
	}

	.btn-dark:hover {
		background: var(--primary-color);
		color: white;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.hero-section {
			grid-template-columns: 1fr;
			text-align: center;
			gap: 1.5rem;
			padding: 2rem 0;
			margin-bottom: 2rem;
		}

		.hero-content h1 {
			font-size: 2.25rem;
		}

		.hero-content p {
			font-size: 1.1rem;
			margin: 0 auto 1.5rem;
		}

		.hero-actions {
			justify-content: center;
			flex-direction: column;
			gap: 0.75rem;
		}

		.hero-actions .btn {
			width: 100%;
		}

		.hero-image {
			order: -1;
		}

		.section-header {
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: 0.75rem;
			margin-bottom: 2rem;
		}

		.section-header h2 {
			font-size: 1.75rem;
		}

		.course-grid {
			gap: 1.5rem;
		}

		.course-content {
			padding: 0.5rem 1.25rem 1.25rem;
		}

		.cta-card {
			padding: 2.5rem 1.5rem;
		}

		.cta-card h2 {
			font-size: 1.75rem;
		}

		.cta-card p {
			font-size: 1.1rem;
		}
	}
</style>
