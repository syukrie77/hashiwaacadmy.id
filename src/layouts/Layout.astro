---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Hashiwa E-Learning",
	description = "Hashiwa Japanese Academy — Pusat studi bahasa Jepang untuk kamu yang siap melangkah dari lokal ke global.",
} = Astro.props;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Hashiwa Japanese Academy</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<header>
			<nav>
				<div class="logo">Hashiwa</div>
				<button class="mobile-menu-toggle" aria-label="Toggle Menu">
					<span></span>
					<span></span>
					<span></span>
				</button>
				<div id="nav-overlay" class="nav-overlay"></div>
				<div class="nav-container">
					<ul class="nav-links">
						<li><a href="/">Home</a></li>
						<li><a href="/dashboard">Dashboard</a></li>
						{
							user?.role === "admin" && (
								<li>
									<a
										href="/admin/dashboard"
										style="color: #ef4444; font-weight: 700;"
									>
										Admin
									</a>
								</li>
							)
						}
						{
							user?.role === "instructor" && (
								<li>
									<a
										href="/instructor/dashboard"
										style="color: #059669; font-weight: 700;"
									>
										Instructor
									</a>
								</li>
							)
						}
					</ul>
					<div class="auth-buttons" id="nav-auth-buttons">
						{
							user ? (
								<div
									class="user-pill-container"
									style="display:flex; gap:10px; align-items:center;"
								>
									<div class="user-pill">
										<a href="/profile" class="profile-link">
											<span class="user-name">
												{user.name}
											</span>
											<span class="user-role-tag">
												{user.role}
											</span>
										</a>
									</div>
									<button
										id="logout-btn"
										class="btn btn-outline"
										style="padding: 0.4rem 0.8rem; border-color: #ef4444; color: #ef4444; line-height: 1;"
									>
										Logout
									</button>
								</div>
							) : (
								<>
									<a href="/login" class="btn btn-outline">
										Login
									</a>
									<a href="/register" class="btn btn-primary">
										Sign Up
									</a>
								</>
							)
						}
					</div>
				</div>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<script>

			const navContainer = document.querySelector(".nav-container");
			const navOverlay = document.getElementById("nav-overlay");
			const menuToggle = document.querySelector(".mobile-menu-toggle");

			// Mobile menu logic
			const mobileLinks = document.querySelectorAll(".nav-links a");
			const mobileAuthButtons = document.querySelectorAll(
				".auth-buttons a, .auth-buttons button",
			);

			function toggleMenu() {
				menuToggle?.classList.toggle("active");
				navContainer?.classList.toggle("active");
				navOverlay?.classList.toggle("active");
				document.body.style.overflow = navContainer?.classList.contains(
					"active",
				)
					? "hidden"
					: "";
			}

			function closeMenu() {
				menuToggle?.classList.remove("active");
				navContainer?.classList.remove("active");
				navOverlay?.classList.remove("active");
				document.body.style.overflow = "";
			}

			menuToggle?.addEventListener("click", toggleMenu);
			navOverlay?.addEventListener("click", closeMenu);

			// Auto close menu when clicking links
			mobileLinks.forEach((link) =>
				link.addEventListener("click", closeMenu),
			);
			mobileAuthButtons.forEach((btn) =>
				btn.addEventListener("click", closeMenu),
			);

			// Logout logic
			const logoutBtn = document.getElementById("logout-btn");
			if (logoutBtn) {
				logoutBtn.addEventListener("click", async () => {
					try {
						await fetch("/api/auth/logout", { method: "POST" });
						localStorage.removeItem("user"); // Cleanup old client session if any
						window.location.href = "/";
					} catch (e) {
						console.error("Logout failed:", e);
					}
				});
			}
		</script>
		<footer>
			<p>&copy; {new Date().getFullYear()} Hashiwa E-Learning. All rights reserved.</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--primary-color: #f59e0b;
		--primary-hover: #d97706;
		--text-color: #1f2937;
		--bg-color: #f9fafb;
		--card-bg: #ffffff;
		--border-color: #e7e5e4;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		font-family: "Inter", sans-serif;
		background-color: var(--bg-color);
		color: var(--text-color);
		height: 100%;
		background-image: radial-gradient(#e5e7eb 1px, transparent 1px);
		background-size: 24px 24px;
	}

	header {
		background-color: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border-color);
		padding: 1rem 2rem;
		position: sticky;
		top: 0;
		z-index: 100;
	}

	nav {
		display: flex;
		justify-content: space-between;
		align-items: center;
		max-width: 1200px;
		margin: 0 auto;
	}

	.logo {
		font-weight: 800;
		font-size: 1.5rem;
		color: var(--primary-color);
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.nav-container {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.nav-links {
		list-style: none;
		display: flex;
		gap: 2rem;
		margin: 0;
		padding: 0;
	}

	.nav-links a {
		text-decoration: none;
		color: var(--text-color);
		font-weight: 500;
		transition: color 0.2s;
	}

	.nav-links a:hover {
		color: var(--primary-color);
	}

	.auth-buttons {
		display: flex;
		gap: 1rem;
		align-items: center;
	}

	.user-pill {
		background: white;
		padding: 0.4rem 0.8rem;
		border-radius: 9999px;
		border: 1px solid var(--border-color);
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
	}

	.profile-link {
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.user-name {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--text-color);
	}

	.user-role-tag {
		font-size: 0.7rem;
		background: var(--bg-color);
		padding: 0.1rem 0.4rem;
		border-radius: 4px;
		color: #92400e;
		text-transform: uppercase;
		font-weight: 700;
		border: 1px solid #fef3c7;
	}

	.mobile-menu-toggle {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 5px;
		z-index: 1001; /* Ensure it's above the nav-container (1000) */
	}

	.mobile-menu-toggle span {
		display: block;
		width: 25px;
		height: 2px;
		background-color: var(--text-color);
		transition: 0.3s;
	}

	.btn {
		padding: 0.5rem 1rem;
		border-radius: 0.375rem;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.2s;
		display: inline-block;
		text-align: center;
	}

	.btn-outline {
		border: 1px solid var(--border-color);
		color: var(--text-color);
		background: white;
	}

	.btn-outline:hover {
		background-color: var(--bg-color);
		border-color: var(--primary-hover);
	}

	.btn-primary {
		background-color: var(--primary-color);
		color: #000000; /* Black text for better contrast on Gold */
		border: 1px solid var(--primary-color);
		box-shadow: 0 2px 4px rgba(245, 158, 11, 0.2);
	}

	.btn-primary:hover {
		background-color: var(--primary-hover);
		border-color: var(--primary-hover);
		transform: translateY(-1px);
	}

	main {
		max-width: 1200px;
		margin: 2rem auto;
		padding: 0 2rem;
		min-height: 80vh;
	}

	footer {
		text-align: center;
		padding: 2rem;
		color: #6b7280;
		background-color: var(--card-bg);
		border-top: 1px solid var(--border-color);
	}

	/* Responsive Design */
	@media (max-width: 768px) {
		header {
			padding: 1rem;
		}

		.mobile-menu-toggle {
			display: flex;
		}

		.mobile-menu-toggle.active span:nth-child(1) {
			transform: translateY(7px) rotate(45deg);
		}
		.mobile-menu-toggle.active span:nth-child(2) {
			opacity: 0;
		}
		.mobile-menu-toggle.active span:nth-child(3) {
			transform: translateY(-7px) rotate(-45deg);
		}

		/* Prevent horizontal scroll from off-canvas menu */
		html,
		body {
			overflow-x: hidden;
		}

		.nav-container {
			position: fixed;
			top: 0;
			right: 0;
			width: 80%;
			max-width: 300px;
			height: 100vh;
			background: white;
			flex-direction: column;
			padding: 6rem 2rem 2rem; /* Increased top padding to clear the toggle button */
			box-shadow: -10px 0 30px rgba(0, 0, 0, 0.1);

			/* Use transform for better performance and reliability */
			transform: translateX(100%);
			transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);

			z-index: 1000;
			align-items: stretch;
			overflow-y: auto; /* Allow scrolling if menu is tall */
		}

		.nav-container.active {
			/* Slide in */
			transform: translateX(0);
		}

		/* Overlay for mobile menu */
		.nav-overlay {
			display: none;
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100vh;
			background: rgba(0, 0, 0, 0.4);
			backdrop-filter: blur(4px);
			z-index: 999;
			opacity: 0;
			transition: opacity 0.3s ease;
		}

		.nav-overlay.active {
			display: block;
			opacity: 1;
		}

		.nav-links {
			flex-direction: column;
			width: 100%;
			gap: 1.5rem;
		}

		.nav-links a {
			font-size: 1.1rem;
			display: block;
			padding: 0.5rem 0;
		}

		.auth-buttons {
			width: 100%;
			flex-direction: column;
			margin-top: 2rem;
			gap: 1rem;
		}

		.auth-buttons .btn {
			width: 100%;
		}

		main {
			padding: 0 1rem;
			margin: 1rem auto;
		}
	}
</style>
