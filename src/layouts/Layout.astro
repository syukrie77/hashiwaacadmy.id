<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Hashiwa E-Learning</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<header>
			<nav>
				<div class="logo">Hashiwa</div>
				<button class="mobile-menu-toggle" aria-label="Toggle Menu">
					<span></span>
					<span></span>
					<span></span>
				</button>
				<div id="nav-overlay" class="nav-overlay"></div>
				<div class="nav-container">
					<ul class="nav-links">
						<li><a href="/">Home</a></li>
						<li><a href="/dashboard">Dashboard</a></li>
					</ul>
					<div class="auth-buttons" id="nav-auth-buttons">
						<a href="/login" class="btn btn-outline">Login</a>
						<a href="/register" class="btn btn-primary">Sign Up</a>
					</div>
				</div>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<script>
			const userStr = localStorage.getItem("user");
			console.log("Layout.astro loaded with Gold Theme");
			const authContainer = document.getElementById("nav-auth-buttons");
			const navLinks = document.querySelector(".nav-links");
			const navContainer = document.querySelector(".nav-container");
			const navOverlay = document.getElementById("nav-overlay");

			// Mobile menu logic
			const menuToggle = document.querySelector(".mobile-menu-toggle");

			function toggleMenu() {
				menuToggle?.classList.toggle("active");
				navContainer?.classList.toggle("active");
				navOverlay?.classList.toggle("active");
				document.body.style.overflow = navContainer?.classList.contains(
					"active",
				)
					? "hidden"
					: "";
			}

			menuToggle?.addEventListener("click", toggleMenu);
			navOverlay?.addEventListener("click", toggleMenu);

			if (userStr && authContainer) {
				const user = JSON.parse(userStr);

				// Added Admin link for admin users
				if (user.role === "admin" && navLinks) {
					const adminLi = document.createElement("li");
					adminLi.innerHTML =
						'<a href="/admin/dashboard" style="color: #ef4444; font-weight: 700;">Admin</a>';
					navLinks.appendChild(adminLi);
				}

				// Added Instructor link for instructor users
				if (user.role === "instructor" && navLinks) {
					const instructorLi = document.createElement("li");
					instructorLi.innerHTML =
						'<a href="/instructor/dashboard" style="color: #059669; font-weight: 700;">Instructor</a>';
					navLinks.appendChild(instructorLi);
				}

				authContainer.innerHTML = `
					<div class="user-pill">
						<a href="/profile" class="profile-link">
							<span class="user-name">${user.name}</span>
							<span class="user-role-tag">${user.role}</span>
						</a>
					</div>
				`;
			}
		</script>
		<footer>
			<p>&copy; 2024 Hashiwa E-Learning. All rights reserved.</p>
		</footer>
	</body>
</html>

