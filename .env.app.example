# ============================================
# Hashiwa Academy - App Environment Variables
# Copy ke .env.app di VPS: cp .env.app.example .env.app
# ============================================

# --- Supabase Config ---
# Client-side URL (harus bisa diakses dari browser pengguna)
PUBLIC_SUPABASE_URL=https://api.hashiwaacademy.id

# Supabase Anon Key (dapatkan dari server Supabase: cat .env | grep ANON_KEY)
PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Server-side internal URL (Docker internal network - TIDAK perlu diubah)
# Ini menghubungkan app ke Kong container secara internal
SUPABASE_INTERNAL_URL=http://supabase2-kong:8000

# --- App Config ---
# Port untuk Astro app (default 4321)
APP_PORT=4321

# --- Docker Network ---
# Nama network Docker Supabase (cek dengan: docker network ls)
# Biasanya format: <nama_folder_supabase>_default
DOCKER_NETWORK_NAME=supabase_default