# ============================================
# GitHub Webhook Server Configuration
# Copy ke .env.webhook di VPS
# ============================================

# Port untuk webhook server
# Pastikan port ini bisa diakses dari GitHub
# (biasanya di belakang reverse proxy seperti Nginx)
WEBHOOK_PORT=3001

# GitHub Webhook Secret
# Dapatkan dari GitHub Repository Settings > Webhooks
# Buat random string dan set di sini
# Contoh: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Path ke repository di VPS
# Tempat folder hashiwa-app di-clone
# Contoh: /home/user/hashiwa-app
REPO_PATH=/path/to/hashiwa-app

# Branch yang akan di-watch untuk auto-deploy
# Biasanya "main" atau "master"
BRANCH=main
